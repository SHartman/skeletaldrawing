---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { expandClades } from '../../lib/clades';
import silData from '../../data/silhouettes.json';

// The "Skeletals" launcher (CLAUDE.md §5 / search handoff): a typeahead that jumps straight to a
// taxon/specimen page, plus clade "doorways" into the galleries. Deliberately NOT the home and NOT
// the gallery grid — search is the focused "I know what I want" counterpart to browsing.
const taxa = await getCollection('taxa');
const specimens = await getCollection('specimens');
const taxonById = new Map(taxa.map((t) => [t.id, t]));
const familyOf = (d: any) => d.family ?? expandClades(d.clade).at(-1) ?? '';

// Search corpus, wired to live records: { taxon, common, clade, specimen, href }.
// (No common-name field on the schema yet — `common` stays empty until one is added; binomial,
// specimen and clade search already cover most queries.)
// `aka` = alsoKnownAs synonyms (former combinations), searchable but not shown in the result meta —
// so a search for "Lagosuchus" surfaces the Marasuchus skeletal where the debate is written up.
type Row = { taxon: string; common: string; clade: string; specimen: string; href: string; aka: string };
const corpus: Row[] = [];
for (const t of taxa) {
  corpus.push({
    taxon: t.data.taxon,
    common: t.data.commonName ?? '', // popular name (e.g. "Northern Cardinal") → searchable
    aka: t.data.alsoKnownAs.join(' '), // former genus combinations → searchable (Lagosuchus → Marasuchus)
    clade: familyOf(t.data),
    // include the nickname (specimenName) so a named skeletal — Triceratops sp. "Yoshi",
    // Brachylophosaurus "Elvis" — is findable by its nickname, mirroring how specimens index theirs.
    specimen: t.data.specimenName
      ? t.data.specimenId
        ? `${t.data.specimenId} · ${t.data.specimenName}`
        : t.data.specimenName
      : t.data.specimenId ?? '',
    href: `/${t.data.gallery}/${t.id}/`,
  });
}
for (const s of specimens) {
  const parent = taxonById.get(s.data.taxon);
  if (!parent) continue;
  corpus.push({
    taxon: parent.data.taxon,
    common: parent.data.commonName ?? '', // inherit the parent taxon's popular name
    aka: parent.data.alsoKnownAs.join(' '),
    clade: familyOf(parent.data),
    specimen: s.data.nickname ? `${s.data.catalog} · ${s.data.nickname}` : s.data.catalog,
    href: `/${parent.data.gallery}/${parent.id}/${s.id}/`,
  });
}

// Synthetic genus-hub rows — a multi-species genus is a first-class destination (its hub at
// /<gallery>/<genus>/), so it's searchable in its own right ALONGSIDE the individual species, which
// stay indexed above (search is the technical, drill-anywhere counterpart to the collapsed gallery).
// The ≥2-species threshold + free-slug guard mirror the router and the gallery collapse, so a row
// never points at a hub that isn't generated.
const taxonIdSet = new Set(taxa.map((t) => t.id));
const genusBuckets = new Map<string, { genus: string; slug: string; gallery: string; species: typeof taxa }>();
for (const t of taxa) {
  const genus = t.data.taxon.split(' ')[0];
  const slug = genus.toLowerCase();
  const key = `${t.data.gallery}::${slug}`;
  const b = genusBuckets.get(key) ?? { genus, slug, gallery: t.data.gallery, species: [] as typeof taxa };
  b.species.push(t);
  genusBuckets.set(key, b);
}
for (const b of genusBuckets.values()) {
  if (b.species.length < 2 || taxonIdSet.has(b.slug)) continue;
  // The genus's family line: the deepest clade every species in it shares (a genus is monophyletic).
  const paths = b.species.map((s) => expandClades(s.data.clade));
  const minDepth = Math.min(...paths.map((p) => p.length));
  let family = paths[0][0] ?? '';
  for (let i = 0; i < minDepth; i++) {
    const c = paths[0][i];
    if (paths.every((p) => p[i] === c)) family = c;
    else break;
  }
  corpus.push({
    taxon: b.genus,
    common: '',
    aka: '',
    clade: family,
    specimen: `${b.species.length} species`,
    href: `/${b.gallery}/${b.slug}/`,
  });
}
corpus.sort((a, b) => a.taxon.localeCompare(b.taxon));

// Curated clade shortcuts — jump straight to a popular clade that sits several levels DOWN in a
// gallery, so a visitor who wants (say) pterosaurs doesn't have to know they live inside the
// "non-dinosaurs" gallery and drill for them. NOT gallery doorways (that's what "Browse galleries →"
// is for). Each deep-links via /<gallery>/#<clade> — the gallery reads the hash and opens pre-drilled.
// Only chips whose clade currently has taxa render, so the list can carry entries for clades that
// don't exist yet: they light up on their own when their gallery lands. Curate label/order here.
// Each chip pairs a recognizable group name (`label`) with a second register (`sub`) — the plain
// gloss for a technical label, or the formal term for a vernacular one — so both lay and technical
// visitors get a foothold. Owner will refine the exact wording.
const CLADE_SHORTCUTS: { label: string; sub: string; gallery: string; clade: string }[] = [
  // Owner's target set — clades undercut by the gallery structure; dormant until their galleries exist:
  { label: 'Pterosaurs', sub: 'Flying reptiles', gallery: 'non-dinosaurs', clade: 'Pterosauria' },
  { label: 'Ceratopsians', sub: 'Horned dinosaurs', gallery: 'ornithischians', clade: 'Ceratopsia' },
  { label: 'Hadrosaurs', sub: 'Duck-billed dinosaurs', gallery: 'ornithischians', clade: 'Hadrosauridae' },
  { label: 'Ankylosaurs', sub: 'Armored dinosaurs', gallery: 'ornithischians', clade: 'Ankylosauria' },
  { label: 'Ichthyosaurs', sub: 'Marine reptiles', gallery: 'non-dinosaurs', clade: 'Ichthyosauria' },
  { label: 'Pseudosuchians', sub: 'Croc-line archosaurs', gallery: 'non-dinosaurs', clade: 'Pseudosuchia' },
  // Live now — popular clades a few steps down in the existing galleries (interim stand-ins; retire
  // as the target clades above come online):
  { label: 'Tyrannosaurs', sub: 'Tyrant dinosaurs', gallery: 'theropods', clade: 'Tyrannosauroidea' },
  { label: 'Dromaeosaurs', sub: "‘Raptors’", gallery: 'theropods', clade: 'Dromaeosauridae' },
  // Avialae includes Aves — so not "early" birds, and (per the owner) not all avialans are "birds".
  { label: 'Avialans', sub: 'Birds and near-birds', gallery: 'theropods', clade: 'Avialae' },
  { label: 'Spinosaurs', sub: 'Sail-backed hunters', gallery: 'theropods', clade: 'Spinosauridae' },
  { label: 'Titanosaurs', sub: 'Giant sauropods', gallery: 'sauropods-and-kin', clade: 'Titanosauria' },
  { label: 'Diplodocids', sub: 'Whip-tailed sauropods', gallery: 'sauropods-and-kin', clade: 'Diplodocidae' },
];
const cladeCards = CLADE_SHORTCUTS.map((c) => ({
  ...c,
  count: taxa.filter((t) => t.data.gallery === c.gallery && expandClades(t.data.clade).includes(c.clade)).length,
}))
  .filter((c) => c.count > 0) // never a dead link — a clade with no taxa yet simply doesn't render
  .slice(0, 6) // one tidy row on desktop; target clades are listed first, so they take the slots as they activate
  .map((c) => ({
    label: c.label,
    sub: c.sub,
    count: c.count,
    href: `/${c.gallery}/#${encodeURIComponent(c.clade)}`,
  }));

// Idle stat line — real figures.
// "Reconstructions" counts every distinct skeletal reconstruction image — not just the one primary per
// entry, but also the growth-series, alternate-pose, extra-specimen and armour-variant skeletals held as
// additional figures. It EXCLUDES additional figures that aren't skeletal reconstructions: muscle and
// soft-tissue studies, mass-estimate (GDI) diagrams, known-material diagrams, and a skeletal reproduced
// from a published paper (which duplicates the primary). Known-material (rigorous) diagrams never count —
// they show preserved bone, not a reconstruction. (Filename-keyword filter; keep names descriptive.)
const NON_RECON_FIG = /soft.?tissue|muscle|mass.?estimate|\bgdi\b|et-al|dissertation|known-(elements|material)/i;
const reconFigs = (arr: { src: string }[] | undefined) => (arr ?? []).filter((f) => !NON_RECON_FIG.test(f.src)).length;
const reconCount =
  taxa.filter((t) => t.data.reconstruction).length +
  specimens.filter((s) => s.data.reconstruction).length +
  taxa.reduce((n, t) => n + reconFigs(t.data.additionalFigures), 0) +
  specimens.reduce((n, s) => n + reconFigs(s.data.additionalFigures), 0);
const idleStat = `${reconCount} reconstructions · ${taxa.length} taxa · a scale bar for every species`;

// The site's own Sue (T. rex, FMNH PR 2081) body silhouette from the scale-comparison database —
// reused faint behind the header and in the no-match state, so the launcher's mascot is a real
// Hartman skeletal rather than the generic outline the design mockup shipped.
const sue = ((silData as Record<string, any[]>)['tyrannosaurus-rex'] ?? []).find((s) => s.slug === 'sue');
const SIL = sue?.path ?? '';
const SIL_VB = `0 0 ${sue?.w ?? 1000} ${sue?.h ?? 307}`;

// The no-match card uses a different real skeletal — Camarasaurus (a sauropod) — so the page shows a
// second silhouette rather than Sue twice. A famous horned/plated taxon can swap in here once traced.
const cam = ((silData as Record<string, any[]>)['camarasaurus-lewisi'] ?? [])[0];
const NM_SIL = cam?.path ?? SIL;
const NM_SIL_VB = cam ? `0 0 ${cam.w} ${cam.h}` : SIL_VB;

const title = 'Search skeletals — the skeletal database | Skeletal Drawing';
const description =
  'Search Scott Hartman’s skeletal reconstructions by taxon, specimen number, or clade — a fast typeahead that jumps straight to any skeletal, plus clade doorways into the galleries.';
---

<BaseLayout title={title} description={description}>
  <main class="search-page">
    <!-- ===================== search header ===================== -->
    <!-- no overflow:hidden here, so the dropdown can extend over Browse-by-clade; the silhouette is
         clipped by its own inset layer -->
    <section class="search-header">
      <div class="sil-layer" aria-hidden="true">
        <svg viewBox={SIL_VB}><path d={SIL} fill="var(--ink)" fill-rule="evenodd" /></svg>
      </div>
      <!-- inert source for the no-match card's silhouette (a different taxon than the header's Sue).
           A <template> is never rendered, so it can't paint behind the header the way a `hidden` SVG
           did (the [hidden] UA rule doesn't reach an SVG-namespaced root); JS reads the path from it. -->
      <template id="nomatch-sil"><svg viewBox={NM_SIL_VB}><path d={NM_SIL} fill-rule="evenodd" /></svg></template>
      <div class="inner">
        <p class="eyebrow">Skeletal database</p>
        <h1 class="display">Find a <span class="i">skeletal.</span></h1>

        <div class="searchbox-wrap">
          <form class="searchbox" id="search-form" role="search">
            <span class="search-icon" aria-hidden="true">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.3-4.3"></path>
              </svg>
            </span>
            <input
              type="text"
              id="search-input"
              placeholder="Search a taxon, specimen, or common name…"
              aria-label="Search skeletals"
              autocomplete="off"
              aria-controls="dropdown"
            />
            <button type="button" id="search-clear" class="clear" aria-label="Clear search" hidden>×</button>
          </form>
          <div class="dropdown" id="dropdown" role="listbox" aria-label="Search results" hidden></div>
        </div>

        <p class="statline" id="statline" data-idle={idleStat}>{idleStat}</p>
      </div>
    </section>

    <!-- ===================== browse by clade ===================== -->
    <section class="browse">
      <div class="inner">
        <div class="browse-head">
          <h2 class="h2">Browse by clade</h2>
          <a class="browse-link" href="/galleries/">Browse galleries →</a>
        </div>
        <div class="clade-grid" id="clade-grid">
          {cladeCards.map((c) => (
            <a class="clade-card" href={c.href}>
              <span class="c-head">
                <span class="c-name">{c.label}</span>
                <span class="c-gloss">{c.sub}</span>
              </span>
              <span class="c-count">{c.count} skeletals</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <script type="application/json" id="search-corpus" set:html={JSON.stringify(corpus)} />
</BaseLayout>

<script>
  type Row = { taxon: string; common: string; clade: string; specimen: string; href: string; aka: string };
  const CORPUS: Row[] = JSON.parse(document.getElementById('search-corpus')!.textContent!);
  const MAX = 7;

  const input = document.getElementById('search-input') as HTMLInputElement;
  const clearBtn = document.getElementById('search-clear') as HTMLButtonElement;
  const dropdown = document.getElementById('dropdown')!;
  const statline = document.getElementById('statline')!;
  const grid = document.getElementById('clade-grid')!;
  const form = document.getElementById('search-form')!;
  const idleStat = statline.dataset.idle ?? '';
  const nmTpl = document.getElementById('nomatch-sil') as HTMLTemplateElement;
  const nmSvg = nmTpl.content.querySelector('svg')!;
  const silPath = nmSvg.querySelector('path')!.getAttribute('d')!;
  const silVB = nmSvg.getAttribute('viewBox')!;

  const esc = (s: string) =>
    s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]!);

  // Highlight the matched substring of the taxon name in accent gold.
  const highlight = (text: string, q: string) => {
    const i = text.toLowerCase().indexOf(q);
    if (i < 0) return esc(text);
    return esc(text.slice(0, i)) + '<span class="hl">' + esc(text.slice(i, i + q.length)) + '</span>' + esc(text.slice(i + q.length));
  };

  let isOpen = false;
  let active = -1; // keyboard-highlighted row index
  let currentHrefs: string[] = [];

  function rank(raw: string) {
    const q = raw.trim().toLowerCase();
    return CORPUS.map((d) => {
      const hay = (d.taxon + ' ' + d.common + ' ' + d.specimen + ' ' + d.clade + ' ' + d.aka).toLowerCase();
      if (!hay.includes(q)) return null;
      const t = d.taxon.toLowerCase(), c = d.common.toLowerCase();
      let r = 3;
      if (t.startsWith(q) || (c && c.startsWith(q))) r = 0;
      else if (t.includes(q) || (c && c.includes(q))) r = 1;
      else if (d.specimen.toLowerCase().includes(q)) r = 2;
      return { d, r };
    })
      .filter(Boolean)
      .sort((a, b) => a!.r - b!.r || a!.d.taxon.localeCompare(b!.d.taxon))
      .map((x) => x!.d);
  }

  function render() {
    const raw = input.value;
    const q = raw.trim().toLowerCase();
    clearBtn.hidden = raw.length === 0;

    if (!q) return close();

    const all = rank(raw);
    const shown = all.slice(0, MAX);
    const overflow = all.length - shown.length;
    active = -1;
    currentHrefs = shown.map((d) => d.href);

    const wasClosed = dropdown.hidden; // cascade the rows only on the open transition, not on every keystroke

    if (shown.length) {
      let html = shown
        .map((d, i) => {
          const meta = [d.common, d.specimen, d.clade].filter(Boolean).map(esc).join(' · ');
          return `<a class="sugg" role="option" style="--i:${i}" href="${esc(d.href)}"><span class="s-name">${highlight(d.taxon, q)}</span><span class="s-meta">${meta}</span></a>`;
        })
        .join('');
      if (overflow > 0)
        html += `<a class="overflow-row" href="/galleries/">See all ${all.length} results in the galleries →</a>`;
      dropdown.innerHTML = html;
    } else {
      dropdown.innerHTML =
        `<div class="nomatch"><svg viewBox="${silVB}" aria-hidden="true"><path d="${silPath}" fill="var(--ink)" fill-rule="evenodd"/></svg>` +
        `<p>No taxa match “<span class="i">${esc(raw.trim())}</span>”.</p>` +
        `<a href="/galleries/">Browse all galleries →</a></div>`;
    }

    statline.textContent = all.length === 0 ? 'No matches' : all.length + (all.length === 1 ? ' match' : ' matches');
    dropdown.classList.toggle('just-opened', wasClosed); // arms the row cascade only when freshly opened
    open();
  }

  function open() {
    dropdown.hidden = false;
    grid.classList.add('dimmed');
    if (!isOpen) {
      // fade-in on first open (translateY(-6px)→0, opacity 0→1) — designed but not runnable in the prototype
      requestAnimationFrame(() => dropdown.classList.add('is-open'));
      isOpen = true;
    }
  }

  function close() {
    isOpen = false;
    dropdown.classList.remove('is-open', 'just-opened');
    dropdown.hidden = true;
    dropdown.innerHTML = '';
    grid.classList.remove('dimmed');
    statline.textContent = idleStat;
  }

  function setActive(next: number) {
    const rows = [...dropdown.querySelectorAll<HTMLElement>('.sugg')];
    if (!rows.length) return;
    active = (next + rows.length) % rows.length;
    rows.forEach((r, i) => r.classList.toggle('is-active', i === active));
    rows[active].scrollIntoView({ block: 'nearest' });
  }

  input.addEventListener('input', render);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') { e.preventDefault(); setActive(active + 1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(active - 1); }
    else if (e.key === 'Escape') { input.value = ''; close(); clearBtn.hidden = true; }
    else if (e.key === 'Enter') {
      e.preventDefault();
      const href = active >= 0 ? currentHrefs[active] : currentHrefs[0];
      if (href) window.location.href = href;
    }
  });
  form.addEventListener('submit', (e) => e.preventDefault());
  clearBtn.addEventListener('click', () => { input.value = ''; close(); clearBtn.hidden = true; input.focus(); });

  // Click/tap anywhere outside the search box + results clears and closes it (same as the ×), so you can
  // start a new search without backspacing through a long name.
  const wrap = document.querySelector('.searchbox-wrap')!;
  document.addEventListener('click', (e) => {
    if (input.value && !wrap.contains(e.target as Node)) { input.value = ''; close(); clearBtn.hidden = true; }
  });
</script>

<style>
  .search-page { display: flex; flex-direction: column; }

  /* ---- search header ---- */
  .search-header { position: relative; border-bottom: 1px solid var(--hair); }
  .sil-layer { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
  /* wide screens: sits right and slides left as the window narrows; then pins ~250px from the left
     and lets the tail run off the right, keeping the heading clear on mobile (the one tunable value) */
  .sil-layer svg {
    position: absolute; left: max(250px, calc(100% - 780px)); top: 52%;
    transform: translateY(-50%); width: 720px; height: auto; opacity: .08;
  }
  .search-header .inner {
    position: relative; max-width: var(--measure-max); margin: 0 auto;
    padding: 56px var(--pad-side) 50px;
  }
  .eyebrow {
    margin: 0; font-family: var(--font-mono); font-size: 12px; letter-spacing: .22em;
    text-transform: uppercase; color: var(--slate);
  }
  .display {
    margin: 12px 0 0; font-weight: 500; font-size: clamp(36px, 5vw, 52px);
    line-height: 1.02; letter-spacing: -.02em;
  }
  .display .i { font-style: italic; }

  .searchbox-wrap { position: relative; max-width: 620px; margin-top: 26px; z-index: 50; }
  .searchbox {
    display: flex; align-items: center; background: var(--plate);
    border: 1px solid var(--hair-strong); border-radius: 8px; overflow: hidden;
    box-shadow: 0 1px 2px rgba(0, 0, 0, .04);
    transition: border-color .2s ease, box-shadow .2s ease;
  }
  /* focus bloom — the "tool is ready" cue: border warms to gold, a soft shadow lifts, icon → accent */
  .searchbox:focus-within { border-color: var(--accent-soft); box-shadow: 0 6px 22px rgba(20, 22, 25, .09); }
  .searchbox:focus-within .search-icon { color: var(--accent); }
  .search-icon { display: flex; align-items: center; padding-left: 18px; color: var(--measure); transition: color .2s ease; }
  #search-input {
    flex: 1; border: none; padding: 16px; font-family: var(--font-serif); font-size: 17px;
    background: transparent; color: var(--ink); outline: none;
  }
  #search-input::placeholder { color: var(--measure); }
  .clear {
    border: none; background: transparent; color: var(--slate); padding: 0 16px;
    font-size: 20px; line-height: 1; cursor: pointer;
  }
  .clear:hover { color: var(--ink); }

  /* dropdown container is in the template (scoped styles reach it); its rows are built in JS →
     their styles live in the is:global block below */
  .dropdown {
    position: absolute; left: 0; right: 0; top: calc(100% + 8px);
    background: var(--plate); border: 1px solid var(--hair-strong); border-radius: 8px;
    box-shadow: 0 18px 46px rgba(20, 22, 25, .20); overflow: hidden; z-index: 50;
    /* panel fades in (opacity only); the rows carry the motion via the cascade in the is:global block */
    opacity: 0; transition: opacity .14s ease;
  }
  .dropdown.is-open { opacity: 1; }

  .statline {
    margin: 16px 0 0; font-family: var(--font-mono); font-size: 11.5px; letter-spacing: .1em;
    text-transform: uppercase; color: var(--measure);
  }

  /* ---- browse by clade ---- */
  .browse .inner { max-width: var(--measure-max); margin: 0 auto; padding: 52px var(--pad-side) 60px; }
  .browse-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 22px; }
  .h2 { margin: 0; font-weight: 500; font-size: clamp(24px, 3vw, 30px); letter-spacing: -.01em; }
  .browse-link {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
    color: var(--accent); text-decoration: none; white-space: nowrap;
  }
  /* Fixed column counts (6 → 3 → 2) that all divide the six chips evenly, so it's never a lone chip
     orphaned on a second row (auto-fit dropped to 5-across at the site's 1180px measure). */
  .clade-grid {
    display: grid; grid-template-columns: repeat(6, 1fr); gap: 14px;
    transition: opacity .28s ease;
  }
  @media (max-width: 1120px) { .clade-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 620px)  { .clade-grid { grid-template-columns: repeat(2, 1fr); } }
  .clade-grid.dimmed { opacity: .45; } /* soft focus pull toward the suggestions while searching */
  .clade-card {
    display: flex; flex-direction: column; justify-content: space-between; gap: 14px;
    padding: 20px 18px; border: 1px solid var(--hair);
    background: var(--plate); text-decoration: none; border-radius: 5px;
    transition: border-color .16s ease, transform .16s ease;
  }
  .clade-card:hover { border-color: var(--slate); transform: translateY(-2px); }
  .clade-card:active { transform: translateY(0) scale(.99); } /* tactile press */
  .c-head { display: flex; flex-direction: column; gap: 3px; }
  /* vernacular group labels (Tyrannosaurs, Croc-line archosaurs) read cleaner roman than italic */
  .c-name { font-size: 19px; color: var(--ink); line-height: 1.12; }
  .c-gloss { font-size: 13px; line-height: 1.2; color: var(--slate); }
  .c-count {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase;
    color: var(--slate);
  }

  @media (max-width: 600px) {
    .search-header .inner { padding: 40px var(--pad-side) 36px; }
    .browse .inner { padding: 40px var(--pad-side) 48px; }
  }
</style>

<!-- Suggestion rows / no-match are built in the client script (createElement/innerHTML), so they never
     get Astro's scope attribute — their styles are global, anchored under .search-page so nothing leaks. -->
<style is:global>
  .search-page .sugg {
    display: flex; align-items: baseline; justify-content: space-between; gap: 16px;
    padding: 13px 18px; text-decoration: none; border-top: 1px solid var(--hair);
  }
  .search-page .dropdown > .sugg:first-child { border-top: none; }
