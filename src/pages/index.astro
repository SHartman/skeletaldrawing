---
import { getCollection } from 'astro:content';
import { Picture, Image, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Glyph from '../components/Glyph.astro';
import ScaleComparison from '../components/ScaleComparison.astro';
import { loadSkeletal, loadBlogImage } from '../lib/images';
import { inlineEmphasisHtml } from '../lib/schema';
import heroImg from '../assets/home-golden-hero.png';

// Home page — design "Golden Specimen" (HOMEDESIGN.md). Custom chrome (transparent
// header over the hero + its own bio strip/footer), so it runs BaseLayout in `bare` mode.
// Real data where it exists; clearly-flagged placeholders where a section's source
// collection isn't built yet (blog) or an asset hasn't been supplied (hero image).

// Mirrors Masthead.astro's IA: the "Galleries" word opens the gallery grid; the trailing search
// icon (added to .topnav below) opens the /skeletals/ launcher. Kept in sync by hand — the home
// hero has its own light-on-dark masthead rather than the shared component.
const NAV = [
  { label: 'Galleries', href: '/galleries/' },
  { label: 'Learn', href: '/learn/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'About', href: '/about/' },
  // Store hidden until a public storefront ships (~late summer/fall 2026) — see Masthead.astro.
  // { label: 'Store', href: '/store/' },
];

const taxa = await getCollection('taxa'); // used by the featured-reconstruction rotation below

// Scale-comparison sampler — rotates per visit among the hubs that have a comparison figure.
// TOOL enables a "Create your own comparison →" CTA above each hub link. It's null while the
// interactive /compare/ tool is still a prototype (unlinked anywhere); flip it on the day the tool
// launches (alongside the intro blog post) — that's the only change needed here.
const TOOL: { href: string; label: string } | null = null;
// const TOOL = { href: '/compare/', label: 'Create your own comparison →' };
const COMPARISONS = [
  { taxonId: 'diplodocus', total: 3, href: '/sauropods-and-kin/diplodocus/', label: 'Open the Diplodocus hub →',
    note: 'Every reconstruction is measured, so a genus like Diplodocus can be compared specimen against specimen — here its two species and their specimens, with a 1.8 m human for scale.' },
  { taxonId: 'tyrannosaurus-rex', total: 6, href: '/theropods/tyrannosaurus-rex/', label: 'Open the Tyrannosaurus hub →',
    note: 'The best-known Tyrannosaurus rex specimens — Sue, Stan, Scotty and more — drawn to one scale with a 1.8 m human. They differ by only a few percent, but every difference is real.' },
  { taxonId: 'allosaurus-jimmadseni', total: 2, href: '/theropods/allosaurus-jimmadseni/', label: 'Open the Allosaurus jimmadseni hub →',
    note: 'One species at two life stages: subadult “Big Al” (MOR 693) beside juvenile “Little Al”, drawn to a common scale with a 1.8 m human.' },
  { taxonId: 'archaeopteryx-lithographica', total: 2, href: '/theropods/archaeopteryx-lithographica/', label: 'Open the Archaeopteryx hub →',
    note: 'Two specimens of the crow-sized “first bird” Archaeopteryx — the Thermopolis and Chicago individuals — at a common scale, measured in centimeters.' },
];

// Featured reconstruction — rotates (weighted toward newest) among the most-recently-added
// reconstructions. "Recent" = entries carrying an `added` date (CMS-stamped on create),
// sorted newest-first, top N. The server renders the newest; the client may rotate to another.
const specimens = await getCollection('specimens');
const taxaById = new Map(taxa.map((t) => [t.id, t]));

interface Recon {
  added: Date;
  src: string;
  alt: string;
  taxon: string;
  href: string;
  specimenLine: string;
  scaleBar: string;
}
const recons: Recon[] = [];
for (const t of taxa) {
  if (t.data.reconstruction && t.data.added && !t.data.underRevision) {
    recons.push({
      added: t.data.added,
      src: t.data.reconstruction.src,
      alt: t.data.reconstruction.alt,
      taxon: t.data.taxon,
      href: `/${t.data.gallery}/${t.id}/`,
      specimenLine: t.data.specimenId ?? t.data.family ?? t.data.clade.at(-1) ?? '',
      scaleBar: t.data.scaleBar,
    });
  }
}
for (const s of specimens) {
  const parent = taxaById.get(s.data.taxon);
  if (s.data.reconstruction && s.data.added && parent) {
    recons.push({
      added: s.data.added,
      src: s.data.reconstruction.src,
      alt: s.data.reconstruction.alt,
      taxon: parent.data.taxon,
      href: `/${parent.data.gallery}/${s.data.taxon}/${s.id}/`,
      specimenLine: s.data.nickname ? `${s.data.catalog} · “${s.data.nickname}”` : s.data.catalog,
      scaleBar: s.data.scaleBar,
    });
  }
}
recons.sort((a, b) => b.added.getTime() - a.added.getTime());

// Pool carries optimized webp URLs so a client-swapped plate stays light.
const POOL_SIZE = 6;
const pool = await Promise.all(
  recons.slice(0, POOL_SIZE).map(async (r, i) => {
    const meta = await loadSkeletal(r.src);
    const img = meta ? (await getImage({ src: meta, format: 'webp', width: 1400 })).src : r.src;
    return {
      img,
      alt: r.alt,
      taxon: r.taxon,
      href: r.href,
      specimenLine: r.specimenLine,
      credit: `Scale bar = ${r.scaleBar} · © Scott Hartman`,
      newest: i === 0,
    };
  }),
);
const featured = pool[0] ?? null;

// Blog — real posts, newest first. Lead = the featured post (else newest); the rest fill "More recent".
const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const fmtDate = (dt: Date) =>
  dt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
const leadEntry = allPosts.find((p) => p.data.featured) ?? allPosts[0] ?? null;
const leadPost = leadEntry
  ? {
      kind: leadEntry.data.kind,
      title: leadEntry.data.title,
      excerpt: leadEntry.data.excerpt,
      date: fmtDate(leadEntry.data.date),
      href: `/blog/${leadEntry.id}/`,
      image: leadEntry.data.image,
      // Rendered at most 202px tall here, so serving the raw upload meant the home page could pull
      // a megabyte-plus for a thumbnail. Falls back to the public path if the mirror hasn't run.
      img: leadEntry.data.image ? await loadBlogImage(leadEntry.data.image.src) : null,
    }
  : null;
const morePosts = allPosts
  .filter((p) => p !== leadEntry)
  .slice(0, 2)
  .map((p) => ({ kind: p.data.kind, title: p.data.title, date: fmtDate(p.data.date), href: `/blog/${p.id}/` }));

// og:image uses the stable public PNG (Astro-optimized URLs are hashed, not share-stable).
const ogImage = new URL('/images/home-golden-hero.png', Astro.site).href;
const title = 'Skeletal Drawing — scientific reconstructions by Dr. Scott Hartman';
const description =
  'Rigorous skeletal reconstructions and life restorations of extinct animals, drawn from the fossils themselves, by vertebrate paleontologist Dr. Scott Hartman.';
---

<BaseLayout title={title} description={description} ogImage={ogImage} bare>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <Picture
      src={heroImg}
      formats={['avif', 'webp']}
      alt="Silhouette of a feathered theropod wading at golden hour"
      widths={[800, 1280, 1920, 2560, 3200]}
      sizes="100vw"
      class="hero-img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-grad-top"></div>
    <div class="hero-grad-bottom"></div>

    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">
          <span class="brand-word"><span class="brand-strong">Skeletal</span> <span class="brand-italic">Drawing</span></span>
          <Glyph />
        </a>
        <nav class="topnav" aria-label="Primary">
          {NAV.map((item, i) => (
            <a href={item.href} class:list={{ dim: i !== 0 }}>{item.label}</a>
          ))}
          <a class="search-link" href="/skeletals/" aria-label="Search skeletals" title="Search skeletals">
            <svg class="search-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.3-4.3"></path>
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <div class="hero-foot">
      <div class="hero-foot-inner">
        <div class="hero-copy">
          <p class="hero-eyebrow">Dr. Scott Hartman</p>
          <h1 class="hero-h1">Bringing extinct animals back to <span class="i">scientific life.</span></h1>
          <p class="hero-sub">Rigorous skeletal reconstructions, drawn from the fossils themselves.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ NEWEST RECONSTRUCTION ============ -->
  <section class="band newest">
    <div class="cta-row">
      <a class="btn btn-gold" href="/galleries/">Explore the galleries →</a>
      <a class="btn btn-plain" href="/skeletals/">Search the database</a>
    </div>

    {featured && (
      <>
        <figure class="plate">
          <a href={featured.href} class="plate-link" id="feat-link">
            <img src={featured.img} alt={featured.alt} class="plate-img" id="feat-img" loading="lazy" />
          </a>
          <div class="plate-rule"></div>
          <div class="plate-credit" id="feat-credit">{featured.credit}</div>
        </figure>

        <div class="newest-meta">
          <p class="newest-eyebrow" id="feat-eyebrow">{featured.newest ? 'Just added · newest reconstruction' : 'Recent work · from the galleries'}</p>
          <a href={featured.href} class="newest-taxon-link" id="feat-taxon-link"><div class="newest-taxon" id="feat-taxon">{featured.taxon}</div></a>
          <div class="newest-specimen" id="feat-specimen">{featured.specimenLine}</div>
        </div>

        <script type="application/json" id="feat-pool" is:inline set:html={JSON.stringify(pool)}></script>
        <script is:inline>
          (() => {
            const el = document.getElementById('feat-pool');
            if (!el) return;
            const pool = JSON.parse(el.textContent);
            if (pool.length < 2) return;
            // weighted: newest gets weight N, oldest gets 1
            const n = pool.length;
            const weights = [];
            let total = 0;
            for (let i = 0; i < n; i++) { weights.push(n - i); total += n - i; }
            let r = Math.random() * total, idx = 0;
            for (let i = 0; i < n; i++) { r -= weights[i]; if (r < 0) { idx = i; break; } }
            if (idx === 0) return; // newest already rendered
            const p = pool[idx];
            const set = (id, fn) => { const e = document.getElementById(id); if (e) fn(e); };
            set('feat-img', (e) => { e.src = p.img; e.alt = p.alt; });
            set('feat-link', (e) => (e.href = p.href));
            set('feat-taxon-link', (e) => (e.href = p.href));
            set('feat-taxon', (e) => (e.textContent = p.taxon));
            set('feat-specimen', (e) => (e.textContent = p.specimenLine));
            set('feat-credit', (e) => (e.textContent = p.credit));
            set('feat-eyebrow', (e) => (e.textContent = p.newest ? 'Just added · newest reconstruction' : 'Recent work · from the galleries'));
          })();
        </script>
      </>
    )}
  </section>

  <!-- ============ DRAWN TO SCALE (rotating sampler from the hubs with a comparison) ============ -->
  <section class="band bordered">
    <div class="band-inner">
      {COMPARISONS.map((c, i) => (
        <div class="comp-slide" data-comp hidden={i !== 0}>
          <ScaleComparison
            taxonId={c.taxonId}
            total={c.total}
            heading="Drawn to scale"
            href={c.href}
            linkLabel={c.label}
            note={c.note}
            toolHref={TOOL?.href}
            toolLabel={TOOL?.label}
          />
        </div>
      ))}
    </div>
    <script is:inline>
      // Rotate the sampler per visit: the server renders the first slide; this shows a random one.
      (() => {
        const slides = Array.from(document.querySelectorAll('[data-comp]'));
        if (slides.length < 2) return;
        const pick = Math.floor(Math.random() * slides.length);
        slides.forEach((s, i) => { s.hidden = i !== pick; });
      })();
    </script>
  </section>

  <!-- ============ FROM THE BLOG ============ -->
  <section class="band bordered">
    <div class="band-inner">
      <div class="sec-head">
        <h2 class="sec-title">From the blog</h2>
        <a class="sec-link" href="/blog/">All posts →</a>
      </div>
      <div class="blog-grid">
        {leadPost && (
          <a class="lead-post" href={leadPost.href}>
            <div class="lead-thumb">
              {leadPost.image ? (
                leadPost.img ? (
                  <Image src={leadPost.img} alt={leadPost.image.alt} widths={[320, 640]} sizes="300px" class="lead-img" loading="lazy" />
                ) : (
                  <img src={leadPost.image.src} alt={leadPost.image.alt} class="lead-img" />
                )
              ) : (
                <span class="thumb-ph">image to come</span>
              )}
            </div>
            <div class="lead-body">
              {leadPost.kind && <span class="post-kind">{leadPost.kind}</span>}
              <h3 class="lead-title">{leadPost.title}</h3>
              {leadPost.excerpt && <p class="lead-excerpt" set:html={inlineEmphasisHtml(leadPost.excerpt)}></p>}
              <div class="lead-foot">
                <span class="read-more">Read more →</span>
                <span class="post-date">{leadPost.date}</span>
              </div>
            </div>
          </a>
        )}
        {morePosts.length > 0 && (
          <div class="more-posts">
            <p class="more-label">More recent</p>
            {morePosts.map((p) => (
              <a class="more-post" href={p.href}>
                {p.kind && <span class="post-kind sm">{p.kind}</span>}
                <span class="more-title">{p.title}</span>
                <span class="post-date">{p.date}</span>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ============ BIO STRIP ============ -->
  <div class="bio">
    <div class="bio-inner">
      <p class="bio-text">Skeletal reconstructions by <strong>Dr. Scott Hartman</strong> — vertebrate paleontologist. Three decades of specimen-based drawings used in peer-reviewed research, museum exhibits, TV and print.</p>
      <div class="bio-cta">
        <a class="btn btn-gold sm" href="/about/">About Scott</a>
        <a class="btn btn-dark sm" href="/store/">Licensing</a>
        <a class="btn btn-dark sm" href="/contact/">Contact</a>
      </div>
    </div>
  </div>

  <!-- ============ FOOTER ============ -->
  <footer class="home-footer">
    <div class="home-footer-inner">
      <span class="foot-word"><span class="brand-strong">Skeletal</span> <span class="foot-italic">Drawing</span></span>
      <span>© 2026 Scott Hartman · paleontological illustration since 1997</span>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ---- hero ---- */
  /* Warm-gold backing (the hero image's own sky tone) so any brief pre-decode gap on a warm navigation
     blends with the image instead of flashing the dark charcoal through. */
  .hero { position: relative; background: #d0a24e; }
  .hero-img {
    display: block; width: 100%; height: clamp(440px, 56vw, 560px);
    object-fit: cover; object-position: 50% 36%;
  }
  /* Narrow screens crop this landscape image into a near-portrait slot. Anchor the crop to the HEAD
     (left of frame) so the head + neck stay in view and the long tail runs off the right, rather than
     centering on the legs. Desktop keeps 50% so the head still sits over "Scott" in the byline. */
  @media (max-width: 1100px) { .hero-img { object-position: 20% 36%; } }
  .hero-grad-top {
    position: absolute; top: 0; left: 0; right: 0; height: 160px;
    background: linear-gradient(to bottom, rgba(12,11,9,.5), rgba(12,11,9,0));
  }
  .hero-grad-bottom {
    position: absolute; bottom: 0; left: 0; right: 0; height: 62%;
    background: linear-gradient(to top, rgba(12,11,9,.84), rgba(12,11,9,0));
  }

  .topbar { position: absolute; top: 0; left: 0; right: 0; }
  .topbar-inner {
    max-width: 1280px; margin: 0 auto; padding: 21px 56px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; color: #fff; white-space: nowrap; }
  .brand-word { font-size: 21px; letter-spacing: .01em; }
  .brand-strong { font-weight: 600; }
  .brand-italic { font-style: italic; color: rgba(255,255,255,.78); }
  .topnav {
    display: flex; gap: 28px; font-family: var(--font-mono); font-size: 12px;
    text-transform: uppercase; letter-spacing: .16em;
  }
  .topnav a { color: #fff; text-decoration: none; }
  .topnav a.dim { color: rgba(255,255,255,.82); }
  .topnav a:hover { color: #fff; }
  /* search affordance: an icon at the end of the nav, held at the dim weight so it sits quietly */
  .topnav a.search-link { display: inline-flex; align-items: center; color: rgba(255,255,255,.82); }
  .topnav .search-ic { width: 15px; height: 15px; display: block; }

  .hero-foot { position: absolute; left: 0; right: 0; bottom: 0; }
  .hero-foot-inner { max-width: 1280px; margin: 0 auto; padding: 0 56px 52px; }
  .hero-copy { max-width: 820px; animation: riseIn .6s cubic-bezier(.2,.7,.2,1) both; }
  .hero-eyebrow {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: .2em;
    text-transform: uppercase; color: rgba(255,255,255,.82); margin: 0;
  }
  .hero-h1 {
    color: #fff; font-weight: 500; font-size: clamp(38px, 5.4vw, 56px); line-height: 1.04;
    letter-spacing: -.02em; margin: 14px 0 0; text-shadow: 0 2px 34px rgba(0,0,0,.45);
  }
  .hero-h1 .i { font-style: italic; }
  .hero-sub {
    color: rgba(255,255,255,.9); font-size: clamp(17px, 2vw, 19px); line-height: 1.5;
    max-width: 620px; margin: 16px 0 0;
  }

  /* ---- bands ---- */
  .band { max-width: 1280px; margin: 0 auto; }
  .newest { padding: 60px 56px 58px; }
  .bordered { max-width: none; border-top: 1px solid var(--hair); }
  .band-inner { max-width: 1280px; margin: 0 auto; padding: 50px 56px 54px; }

  .cta-row { display: flex; gap: 13px; justify-content: center; flex-wrap: wrap; margin-bottom: 34px; }
  .btn {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase;
    padding: 14px 24px; border-radius: 6px; text-decoration: none; white-space: nowrap;
  }
  .btn.sm { font-size: 11px; padding: 11px 16px; border-radius: 5px; }
  /* Gold buttons: bright gold with DARK text. Dark-on-bright-gold clears AA (~4.8:1); white-on-bright-gold
     would fail (3.2:1), so both gold buttons use dark text and keep the brighter, warmer gold. */
  .btn-gold { color: var(--mast-bg); background: var(--accent-bright); }
  .btn-plain { color: var(--ink); background: var(--plate); border: 1px solid var(--hair-strong); }
  .btn-dark { color: #E7E3DA; border: 1px solid #3A3D40; }
  .btn:hover { opacity: .9; }

  .plate {
    margin: 0; background: var(--plate); border: 1px solid var(--hair); border-radius: 7px;
    padding: clamp(22px, 3vw, 36px) clamp(24px, 4vw, 48px) 26px;
  }
  .plate-link { display: block; text-decoration: none; }
  /* Bounded on BOTH axes. Width alone isn't enough: a portrait plate (Archelon is 3000x4528, ar
     0.66) would render ~1575px tall at full width and shove the rest of the page below the fold.
     Capping the height lets any tall reconstruction scale down and centre instead — the layout is
     immune to shape, so `added` dates stay honest rather than being curated around the bug.
     Wide plates are unaffected: a typical 3:1 skeletal is only ~330px tall at 1040 wide. */
  .plate-img {
    display: block; margin: 0 auto;
    width: auto; height: auto;
    max-width: min(100%, 1040px);
    max-height: 62vh;
  }
  .plate-rule { margin-top: 16px; height: 1px; background: var(--hair); }
  .plate-credit {
    margin-top: 10px; text-align: right; font-family: var(--font-mono); font-size: 10.5px;
    letter-spacing: .1em; text-transform: uppercase; color: var(--measure);
  }

  .newest-meta { text-align: center; margin-top: 20px; }
  .newest-eyebrow {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
    color: var(--accent); margin: 0 0 10px;
  }
  .newest-taxon-link { text-decoration: none; }
  .newest-taxon { font-style: italic; font-size: clamp(22px, 3vw, 26px); color: var(--ink); line-height: 1.1; }
  .newest-specimen {
    font-family: var(--font-mono); font-size: 11.5px; letter-spacing: .06em; color: var(--slate); margin-top: 9px;
  }

  /* ---- section heads ---- */
  .sec-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 22px; }
  .sec-title { font-weight: 500; font-size: clamp(24px, 3vw, 30px); letter-spacing: -.01em; margin: 0; }
  .sec-link {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
    color: var(--accent); text-decoration: none; white-space: nowrap;
  }


  /* ---- blog ---- */
  .blog-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px; align-items: start; }
  .lead-post { display: grid; grid-template-columns: 236px 1fr; gap: 26px; text-decoration: none; align-items: stretch; }
  .lead-post:hover { opacity: .86; }
  .lead-thumb {
    background: var(--plate); border: 1px solid var(--hair); border-radius: 6px; overflow: hidden;
    display: flex; align-items: center; justify-content: center; padding: 14px; min-height: 214px;
  }
  .lead-img { max-width: 100%; max-height: 202px; display: block; }
  .thumb-ph {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--measure);
  }
  .lead-body { align-self: center; }
  .post-kind {
    display: block; font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .14em;
    text-transform: uppercase; color: var(--accent);
  }
  .post-kind.sm { font-size: 9.5px; }
  .lead-title { font-size: clamp(22px, 2.6vw, 27px); line-height: 1.16; letter-spacing: -.01em; margin: 11px 0 0; color: var(--ink); }
  .lead-excerpt { font-size: 16px; line-height: 1.55; color: var(--slate); margin: 13px 0 0; }
  .lead-foot { display: flex; align-items: center; gap: 16px; margin-top: 17px; }
  .read-more { font-family: var(--font-mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); }
  .post-date { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .08em; color: var(--measure); }

  .more-posts { border-left: 1px solid var(--hair); padding-left: 32px; }
  .more-label { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: var(--slate); margin: 0 0 4px; }
  .more-post { display: block; text-decoration: none; padding: 17px 0; border-top: 1px solid var(--hair); }
  .more-post:hover { opacity: .7; }
  .more-title { display: block; font-size: 18px; line-height: 1.25; color: var(--ink); margin-top: 8px; }
  .more-post .post-date { display: block; margin-top: 9px; }

  /* ---- bio strip ---- */
