---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import portrait from '../../assets/about/scott-hartman.jpg';

// About hub (CLAUDE.md §5) — the lede + peer testimonials (the "expertise stamp"), then three doors to
// the ways Scott's work is used: licensing/commissions, media & film, and his academic research &
// teaching. Replaces the old Squarespace dropdown (ME / MY ART / LICENSING / CONTACTING ME /
// PUBLICATIONS): contact is the site-wide /contact/, "my art" (a credits list) folds into Licensing, and
// publications live under Research. The personal biography lives on Scott's separate academic (Hugo) site
// for now — dropped here to avoid duplication; may fold in later. Prose authored in-page (low edit
// frequency); the publications LIST is a CMS collection so it can grow without code.

const doors = [
  {
    href: '/about/licensing/',
    kicker: 'For museums, publishers & educators',
    title: 'Licensing & commissions',
    blurb:
      'Skeletal reconstructions and life restorations to license for exhibits, books, film, and the classroom — or commissioned new for your specimen.',
  },
  {
    href: '/about/media/',
    kicker: 'For documentary & film',
    title: 'Media & film',
    blurb:
      'Scientific consulting, character design and original artwork for productions that want to get the anatomy right.',
  },
  {
    href: '/about/research/',
    kicker: 'At UW–Madison',
    title: 'Research & teaching',
    blurb:
      'Learn more about my publications, teaching and the research that keeps the reconstructions grounded in current science.',
  },
];

const title = 'About Scott Hartman — paleontologist & paleoartist | Skeletal Drawing';
const description =
  'Dr. Scott Hartman is a vertebrate paleontologist, paleoartist, and educator at the University of Wisconsin–Madison. Licensing and commissions, media and film consulting, and research and teaching.';
---

<BaseLayout title={title} description={description} ogType="profile">
  <main class="wrap about">
    <header class="head">
      <div class="head-text">
        <p class="eyebrow">About</p>
        <h1 class="display">Scott Hartman</h1>
        <p class="lede">
          Vertebrate paleontologist, paleoartist, and instructional faculty at the University of
          Wisconsin–Madison. Three decades of experience producing rigorous skeletal reconstructions, used
          in peer-reviewed research, museum exhibits, documentaries, and print.
        </p>
      </div>
      <Image
        src={portrait}
        alt="Scott Hartman, vertebrate paleontologist and paleoartist"
        class="portrait"
        widths={[200, 400]}
        sizes="200px"
        loading="eager"
        fetchpriority="high"
      />
    </header>

    <section class="testimonials">
      <figure class="quote">
        <blockquote>“Scott Hartman's detailed and rigorous skeletal reconstructions set the standard for sauropods: he's now become the first port of call when looking for precise, anatomically correct work.”</blockquote>
        <figcaption>— <a href="https://www.miketaylor.org.uk/" target="_blank" rel="noopener">Dr. Mike Taylor</a>, sauropod palaeontologist</figcaption>
      </figure>
      <figure class="quote">
        <blockquote>“The Master and ‘go-to’ guy for skeletal reconstructions.”</blockquote>
        <figcaption>— <a href="https://scholar.google.com/citations?user=d46ItscAAAAJ" target="_blank" rel="noopener">Dr. Heinrich Mallison</a></figcaption>
      </figure>
    </section>

    <nav class="doors" aria-label="About sections">
      {doors.map((d) => (
        <a class="door" href={d.href}>
          <span class="door-kicker">{d.kicker}</span>
          <span class="door-title">{d.title}</span>
          <span class="door-blurb">{d.blurb}</span>
          <span class="door-go">Read more <span class="arrow">→</span></span>
        </a>
      ))}
    </nav>

    <aside class="contact-cta">
      <p class="cc-text">Have a question, correction or project in mind?</p>
      <a class="cc-btn" href="/contact/">Get in touch →</a>
    </aside>
  </main>
</BaseLayout>

<style>
  .wrap { max-width: var(--measure-max); margin: 0 auto; padding: 0 var(--pad-side); }

  /* Cap the whole header so the text column and portrait fill it side by side — a 1fr text track on
     the full page width would strand the portrait at the far right with a void beside the (capped) text. */
  .head { margin: 48px 0 0; max-width: 920px; display: grid; grid-template-columns: 1fr auto; gap: 36px 48px; align-items: center; }
  .head-text { min-width: 0; } /* fills the text column; the lede governs its own measure */
  .portrait { width: 250px; height: auto; border-radius: 8px; border: 1px solid var(--hair-strong); display: block; }
  .eyebrow {
    margin: 0 0 12px; font-family: var(--font-mono); font-size: 12px; letter-spacing: .22em;
    text-transform: uppercase; color: var(--slate);
  }
  .display {
    margin: 0; font-style: italic; font-weight: 500;
    font-size: clamp(44px, 7vw, 76px); line-height: 1.0; letter-spacing: -.015em;
  }
  /* no tight cap: the lede fills the header text column (which the .head max-width already bounds to a
     readable width) so there's no gap between it and the portrait */
  .lede { margin: 20px 0 0; font-size: 20px; line-height: 1.55; color: var(--ink); }

  /* Peer testimonials stand in for the old bio (which duplicated the Hugo academic site) — a stronger
     expertise stamp. Two gold-bordered pull-quotes, matching the site's quote treatment; side by side on
     desktop, stacked on mobile. */
  .testimonials {
    margin: 34px 0 0; display: grid; gap: 24px 40px;
    /* min(100%, 300px) so the track can never exceed the container — no h-scroll on the narrowest phones */
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
  }
  .testimonials .quote { margin: 0; padding: 3px 0 3px 20px; border-left: 3px solid var(--accent); }
  .testimonials blockquote {
    margin: 0; font-style: italic; font-size: 18.5px; line-height: 1.5; color: var(--ink);
  }
  .testimonials figcaption {
    margin: 12px 0 0; font-family: var(--font-mono); font-size: 11.5px; letter-spacing: .06em;
    text-transform: uppercase; color: var(--slate);
  }
  .testimonials figcaption a { color: inherit; text-decoration: none; border-bottom: 1px solid var(--accent-soft); }
  .testimonials figcaption a:hover { border-bottom-color: var(--accent); }

  .doors {
    margin: 46px 0 0; display: grid; gap: 20px;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .door {
    display: flex; flex-direction: column; gap: 8px; text-decoration: none; color: var(--ink);
    border: 1px solid var(--hair-strong); background: var(--plate); border-radius: 6px; padding: 22px 24px;
    transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
  }
  .door:hover { border-color: var(--slate); transform: translateY(-3px); box-shadow: 0 12px 30px rgba(26,24,21,.10); }
  .door-kicker { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .12em; text-transform: uppercase; color: var(--slate); }
  .door-title { font-style: italic; font-weight: 500; font-size: clamp(22px, 2.6vw, 27px); line-height: 1.1; }
  .door-blurb { font-size: 15px; line-height: 1.55; color: var(--slate); margin-top: 2px; }
  .door-go { margin-top: auto; padding-top: 12px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--accent); }
  .door-go .arrow { transition: margin-left .15s ease; }
  .door:hover .arrow { margin-left: 4px; }

  .contact-cta {
    margin: 40px 0 0; padding: 22px 26px; border-top: 1px solid var(--hair);
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 12px 24px;
  }
  .cc-text { margin: 0; font-size: 17px; color: var(--ink); }
  .cc-btn {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase;
    color: var(--accent); text-decoration: none; white-space: nowrap;
  }
  .cc-btn:hover { text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 720px) {
    .wrap { padding: 0 18px; }
    /* single column: the face sits above the intro so it greets the reader */
    .head { grid-template-columns: 1fr; }
    .portrait { width: 132px; order: -1; }
  }
</style>
