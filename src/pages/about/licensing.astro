---
import BaseLayout from '../../layouts/BaseLayout.astro';

// About → Licensing & commissions. Absorbs the old LICENSING page and the commercial half of "My Art"
// (which was really a credits list, not a gallery — see the "where my work appears" section below;
// its detailed list is owner-supplied). Values note per the owner: license widely, but decline uses
// that misrepresent evolutionary science. CTAs route to /contact/ (Regarding: Licensing & Commissions)
// and, for a specific quote, the Square payment-link flow the owner already uses.

const title = 'Licensing & commissions — Scott Hartman | Skeletal Drawing';
const description =
  'License Scott Hartman’s skeletal reconstructions and life restorations for museums, publishers, film, and the classroom — or commission a new reconstruction for your specimen.';
---

<BaseLayout title={title} description={description}>
  <main class="wrap licensing">
    <header class="head">
      <p class="eyebrow"><a href="/about/">About</a> <span aria-hidden="true">/</span> Licensing &amp; commissions</p>
      <h1 class="display">Licensing &amp; commissions</h1>
      <p class="lede">
        The reconstructions on this site are available to license, and I take on new commissions when a
        project needs a skeletal or life restoration that doesn't exist yet. Both are drawn to the same
        measured, specimen-based method — the reason they hold up in exhibits and peer review.
      </p>
    </header>

    <section class="paths">
      <div class="path">
        <h2 class="path-h">License an existing image</h2>
        <p>
          Any reconstruction in the galleries can be licensed for a museum exhibit, a book or journal, a
          documentary, a classroom, or the web. Tell me which taxon and how you'd like to use it, and I'll
          send a quote and a secure payment link.
        </p>
      </div>
      <div class="path">
        <h2 class="path-h">Commission new work</h2>
        <p>
          Have a specimen, a new taxon, or a specific view that isn't here yet? I produce original skeletal
          reconstructions and colour life restorations to spec, worked up from the fossil material and the
          current literature.
        </p>
      </div>
    </section>

    <section class="appears block">
      <h2 class="sec-h">Where my work appears</h2>
      <p class="appears-lede">
        For two decades my reconstructions have appeared in museum exhibits, textbooks and popular-science
        books, documentaries, and peer-reviewed research around the world.
      </p>
      {/* TODO(owner content): the detailed "selected institutions / books / publications that use my
          work" list from the old My Art page goes here — supply it and it becomes a credits list. */}
    </section>

    <section class="values block">
      <h2 class="sec-h">A note on use</h2>
      <p>
        I license my work widely for research, education, museums, and media. I don't license it to
        organisations that misrepresent or campaign against evolutionary science — the work exists to make
        the real science clearer, and that comes first.
      </p>
    </section>

    <aside class="contact-cta">
      <p class="cc-text">Tell me the taxon and the use, and I'll send a quote.</p>
      <a class="cc-btn" href="/contact/">Start a licensing enquiry →</a>
    </aside>
  </main>
</BaseLayout>

<style>
  .wrap { max-width: var(--measure-max); margin: 0 auto; padding: 0 var(--pad-side); }

  .head { max-width: 64ch; margin: 48px 0 0; }
  .eyebrow {
    margin: 0 0 12px; font-family: var(--font-mono); font-size: 12px; letter-spacing: .18em;
    text-transform: uppercase; color: var(--slate);
  }
  .eyebrow a { color: inherit; text-decoration: none; border-bottom: 1px solid transparent; }
  .eyebrow a:hover { color: var(--ink); border-bottom-color: var(--accent-soft); }
  .display {
    margin: 0; font-style: italic; font-weight: 500;
    font-size: clamp(38px, 6vw, 62px); line-height: 1.0; letter-spacing: -.015em;
  }
  .lede { margin: 20px 0 0; font-size: 18.5px; line-height: 1.62; color: var(--ink); max-width: 62ch; }

  .paths { margin: 40px 0 0; display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .path { border: 1px solid var(--hair-strong); background: var(--plate); border-radius: 6px; padding: 22px 24px; }
  .path-h { margin: 0 0 10px; font-style: italic; font-weight: 500; font-size: 22px; }
  .path p { margin: 0; font-size: 16px; line-height: 1.6; color: var(--slate); }

  .block { margin: 44px 0 0; }
  .sec-h {
    margin: 0 0 14px; font-family: var(--font-mono); font-size: 12px; font-weight: 400;
    letter-spacing: .2em; text-transform: uppercase; color: var(--slate);
  }
  .appears-lede { margin: 0; font-size: 17px; line-height: 1.65; color: var(--ink); max-width: 64ch; }
  .values p { margin: 0; font-size: 17px; line-height: 1.7; color: var(--ink); max-width: 64ch; }

  .contact-cta {
    margin: 40px 0 0; padding: 22px 26px; border-top: 1px solid var(--hair);
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 12px 24px;
  }
  .cc-text { margin: 0; font-size: 17px; color: var(--ink); }
  .cc-btn {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase;
    color: var(--accent); text-decoration: none; white-space: nowrap;
  }
  .cc-btn:hover { text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 600px) {
    .wrap { padding: 0 18px; }
  }
</style>
