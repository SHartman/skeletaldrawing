---
import BaseLayout from '../../layouts/BaseLayout.astro';

// About → Licensing & commissions. Absorbs the old LICENSING page (Scott's reference-vs-commercial
// licensing philosophy, condensed and in his voice) and the commercial half of "My Art" — which was
// really a credits list: institutions and books that feature his work (seeded from the Squarespace
// export; owner may update). Values note per the owner: license widely, decline uses that
// misrepresent evolutionary science. CTAs route to /contact/ (Regarding: Licensing & Commissions)
// and, for a specific quote, the Square payment-link flow the owner already uses.

// Institutions that have featured Scott's reconstructions (names only — the point is the roster;
// links were stale in the old export). Owner can add/prune in this list.
const institutions = [
  'American Museum of Natural History, New York',
  'Smithsonian Institution, Washington, D.C.',
  'Royal Ontario Museum, Toronto',
  'Perot Museum of Nature and Science, Dallas',
  'Oregon Museum of Science and Industry, Portland',
  'Museum of the Rockies, Bozeman, Montana',
  'Philip J. Currie Dinosaur Museum, Alberta',
  'Natural History Museum of Utah, Salt Lake City',
  'Rocky Mountain Dinosaur Resource Center, Colorado',
  'Wyoming Dinosaur Center, Thermopolis',
  'Tate Geological Museum, Casper, Wyoming',
  'University of Wyoming Geological Museum, Laramie',
];

// Popular-science books that feature Scott's artwork (titles only — old affiliate links dropped).
const books = [
  { title: 'ABC Dinosaurs', by: 'American Museum of Natural History' },
  { title: 'All Yesterdays', by: 'Conway, Kosemen & Naish' },
  { title: 'Dinosaur Paleobiology', by: 'Stephen L. Brusatte' },
  { title: 'The Complete Dinosaur', by: 'Indiana University Press' },
  { title: 'Dinosaurs: How to Draw Thunder Lizards', by: 'Steve Miller' },
];

const title = 'Licensing & commissions — Scott Hartman | Skeletal Drawing';
const description =
  'License Scott Hartman’s skeletal reconstructions and life restorations for museums, publishers, film, and the classroom — or commission a new reconstruction for your specimen.';
---

<BaseLayout title={title} description={description}>
  <main class="wrap licensing">
    <header class="head">
      <p class="eyebrow"><a href="/about/">About</a> <span aria-hidden="true">/</span> Licensing &amp; commissions</p>
      <h1 class="display">Licensing &amp; commissions</h1>
      <p class="lede">
        The reconstructions on this site are available to license, and I take on new commissions when a
        project needs a skeletal or life restoration that doesn't exist yet. Both are drawn to the same
        measured, specimen-based method — the reason they hold up in exhibits and peer review.
      </p>
      <!-- Catches visitors redirected from the old /store URL: prints/merchandise aren't live yet, but
           they land somewhere real and get the coming-soon context (CLAUDE.md §6; owner decision). -->
      <p class="shop-soon">
        Looking for prints or merchandise? A shop is on the way — I expect to open it in <strong>fall 2026</strong>.
        For now, image licensing and commissions are handled right here.
      </p>
    </header>

    <figure class="quote">
      <blockquote>
        “Scott Hartman's detailed and rigorous skeletal reconstructions set the standard for sauropods:
        he's now become the first port of call when looking for precise, anatomically correct work.”
      </blockquote>
      <figcaption>— Dr. Mike Taylor, sauropod palaeontologist</figcaption>
    </figure>

    <section class="paths">
      <div class="path">
        <h2 class="path-h">License an existing image</h2>
        <p>
          Any reconstruction in the galleries can be licensed for a museum exhibit, a book or journal, a
          documentary, a classroom, or the web. Tell me which taxon and how you'd like to use it, and I'll
          send a quote and a secure payment link.
        </p>
      </div>
      <div class="path">
        <h2 class="path-h">Commission new work</h2>
        <p>
          Have a specimen, a new taxon, or a specific view that isn't here yet? I produce original skeletal
          reconstructions and colour life restorations to spec, worked up from the fossil material and the
          current literature.
        </p>
      </div>
    </section>

    <section class="block using">
      <h2 class="sec-h">Using them as references</h2>
      <p>
        Skeletal reconstructions combine hard anatomical data with careful inference, so the science in
        them — the proportions, the pose, the shape and position of every bone — isn't mine to own, and I
        want it used. If you're drawing your own skeletal, please adopt the pose (and cite me). What's
        copyrighted is the specific image itself: you can't reproduce the actual drawing — in a book, an
        exhibit, a product — without a licence. Non-commercial reference use is free; commercial
        reproduction needs permission. Either way I'd always rather you get in touch first — I genuinely
        enjoy hearing how the work gets used.
      </p>
    </section>

    <section class="block appears">
      <h2 class="sec-h">Where my work appears</h2>
      <p class="appears-lede">
        For two decades my reconstructions have appeared in museum exhibits, textbooks and popular-science
        books, documentaries, and the peer-reviewed literature. A selection:
      </p>
      <div class="cols">
        <div class="col">
          <h3 class="col-h">Institutions</h3>
          <ul class="tidy">
            {institutions.map((i) => <li>{i}</li>)}
          </ul>
        </div>
        <div class="col">
          <h3 class="col-h">Books</h3>
          <ul class="tidy">
            {books.map((b) => (
              <li><span class="bk-title">{b.title}</span> <span class="bk-by">— {b.by}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="values block">
      <h2 class="sec-h">A note on use</h2>
      <p>
        I license my work widely for research, education, museums, and media. I don't license it to
        organisations that misrepresent or campaign against evolutionary science — the work exists to make
        the real science clearer, and that comes first.
      </p>
    </section>

    <aside class="contact-cta">
      <p class="cc-text">Tell me the taxon and the use, and I'll send a quote.</p>
      <a class="cc-btn" href="/contact/">Start a licensing enquiry →</a>
    </aside>
  </main>
</BaseLayout>

<style>
  .wrap { max-width: var(--measure-max); margin: 0 auto; padding: 0 var(--pad-side); }

  .head { max-width: 64ch; margin: 48px 0 0; }
  .eyebrow {
    margin: 0 0 12px; font-family: var(--font-mono); font-size: 12px; letter-spacing: .18em;
    text-transform: uppercase; color: var(--slate);
  }
  .eyebrow a { color: inherit; text-decoration: none; border-bottom: 1px solid transparent; }
  .eyebrow a:hover { color: var(--ink); border-bottom-color: var(--accent-soft); }
  .display {
    margin: 0; font-style: italic; font-weight: 500;
    font-size: clamp(38px, 6vw, 62px); line-height: 1.0; letter-spacing: -.015em;
  }
  .lede { margin: 20px 0 0; font-size: 18.5px; line-height: 1.62; color: var(--ink); max-width: 62ch; }
  /* Coming-soon aside for visitors redirected from /store — quieter than the lede, gold accent. */
  .shop-soon {
    margin: 18px 0 0; padding: 12px 16px; max-width: 62ch;
    background: var(--plate); border-left: 3px solid var(--accent); border-radius: 0 4px 4px 0;
    font-size: 15px; line-height: 1.55; color: var(--slate);
  }
  .shop-soon strong { color: var(--ink); font-weight: 600; }

  .quote { margin: 34px 0 0; padding: 0 0 0 22px; border-left: 3px solid var(--accent); max-width: 62ch; }
  .quote blockquote { margin: 0; font-size: 20px; line-height: 1.5; font-style: italic; color: var(--ink); }
  .quote figcaption { margin-top: 10px; font-family: var(--font-mono); font-size: 12px; letter-spacing: .06em; color: var(--slate); }

  .paths { margin: 40px 0 0; display: grid; gap: 22px; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .path { border: 1px solid var(--hair-strong); background: var(--plate); border-radius: 6px; padding: 22px 24px; }
  .path-h { margin: 0 0 10px; font-style: italic; font-weight: 500; font-size: 22px; }
  .path p { margin: 0; font-size: 16px; line-height: 1.6; color: var(--slate); }

  .block { margin: 44px 0 0; }
  .sec-h {
    margin: 0 0 14px; font-family: var(--font-mono); font-size: 12px; font-weight: 400;
    letter-spacing: .2em; text-transform: uppercase; color: var(--slate);
  }
  .using p { margin: 0; font-size: 17px; line-height: 1.72; color: var(--ink); max-width: 66ch; }

  .appears-lede { margin: 0 0 22px; font-size: 17px; line-height: 1.65; color: var(--ink); max-width: 64ch; }
  .cols { display: grid; gap: 26px 40px; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  .col-h { margin: 0 0 12px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--measure); }
  .tidy { list-style: none; margin: 0; padding: 0; }
  .tidy li { padding: 7px 0; border-top: 1px solid var(--hair); font-size: 15.5px; line-height: 1.4; color: var(--ink); }
  .tidy li:first-child { border-top: 0; }
  .bk-title { font-style: italic; }
  .bk-by { color: var(--slate); }

  .values p { margin: 0; font-size: 17px; line-height: 1.7; color: var(--ink); max-width: 64ch; }

  .contact-cta {
    margin: 40px 0 0; padding: 22px 26px; border-top: 1px solid var(--hair);
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 12px 24px;
  }
  .cc-text { margin: 0; font-size: 17px; color: var(--ink); }
  .cc-btn {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase;
    color: var(--accent); text-decoration: none; white-space: nowrap;
  }
  .cc-btn:hover { text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 600px) {
    .wrap { padding: 0 18px; }
  }
</style>
