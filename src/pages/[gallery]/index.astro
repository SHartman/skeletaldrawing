---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadSkeletal } from '../../lib/images';
import { heroRef, formatLength } from '../../lib/schema';
import { expandClades, LANDMARKS, POPULAR_MIN } from '../../lib/clades';

// A gallery (section) page per distinct `gallery` bucket → /<gallery>/
export async function getStaticPaths() {
  const taxa = await getCollection('taxa');
  const galleries = [...new Set(taxa.map((t) => t.data.gallery))];
  return galleries.map((gallery) => ({ params: { gallery }, props: { gallery } }));
}

const GALLERY_META: Record<string, { label: string; intro: string }> = {
  'sauropods-and-kin': {
    label: 'Sauropodomorpha',
    intro:
      'Long-necked plant-eaters and their earliest relatives — from cat-sized Triassic forms to the largest animals ever to walk the Earth.',
  },
  theropods: {
    label: 'Theropoda',
    intro: 'Predatory dinosaurs and their kin, including the lineage that became birds.',
  },
  ornithischians: {
    label: 'Ornithischia',
    intro:
      'The bird-hipped dinosaurs — armoured, plated, horned, and duck-billed plant-eaters, from tiny basal forms to the great ceratopsids and hadrosaurs.',
  },
};

const { gallery } = Astro.props;
const meta = GALLERY_META[gallery] ?? { label: gallery, intro: '' };

const all = (await getCollection('taxa')).filter((t) => t.data.gallery === gallery);
all.sort((a, b) => a.data.taxon.localeCompare(b.data.taxon));

// Global taxon-id set — matches the router's guard: a genus only collapses into a hub when no real
// taxon already occupies that slug (see [taxon].astro getStaticPaths). Keeps a card from pointing
// at a synthetic hub the router didn't actually generate.
const allTaxonIds = new Set((await getCollection('taxa')).map((t) => t.id));

// Genus hubs are first-class (CLAUDE.md §5): a multi-species genus collapses into ONE card that
// links to /<gallery>/<genus>/, replacing its per-species cards; discovery of the individual
// species continues from the hub (or from search). The ≥2-species threshold + free-slug guard
// mirror the router so the gallery and the routes agree on which genera become hubs.
const genusGroups = new Map<string, { genus: string; slug: string; species: typeof all }>();
for (const t of all) {
  const slug = t.data.taxon.split(' ')[0].toLowerCase();
  const g = genusGroups.get(slug) ?? { genus: t.data.taxon.split(' ')[0], slug, species: [] as typeof all };
  g.species.push(t);
  genusGroups.set(slug, g);
}

// The deepest clade every species in a genus shares (a genus is monophyletic) — its "family" line
// and the lineage the collapsed card filters under. Mirrors GenusHub's family computation.
function sharedClade(species: typeof all): string[] {
  const paths = species.map((s) => expandClades(s.data.clade)); // each root-first, inclusive
  const minDepth = Math.min(...paths.map((p) => p.length));
  const shared: string[] = [];
  for (let i = 0; i < minDepth; i++) {
    const c = paths[0][i];
    if (paths.every((p) => p[i] === c)) shared.push(c);
    else break;
  }
  return shared;
}

interface Unit {
  isGenus: boolean;
  id: string;
  href: string;
  name: string;         // genus or binomial — rendered italic either way
  fam: string;          // family / most-specific-clade line under the name
  cladePath: string[];  // full lineage (species) or shared lineage (genus) → data-clade + nav counts
  length: string;       // length-badge label (species only)
  speciesCount: number; // >1 marks a genus hub card
  lengthM: number;      // sort key
  massKg: number;       // sort key
  underRevision: boolean;
  img: Awaited<ReturnType<typeof loadSkeletal>>;
  alt: string;
  imgSrc: string;       // raw public path — fallback when the optimizer has no match
}

const units: Unit[] = [];
for (const g of genusGroups.values()) {
  const collapse = g.species.length >= 2 && !allTaxonIds.has(g.slug);
  if (collapse) {
    // Representative plate: the featured species if one is flagged, else the largest.
    const rep =
      g.species.find((s) => s.data.featured) ??
      [...g.species].sort((a, b) => (b.data.lengthM ?? 0) - (a.data.lengthM ?? 0))[0];
    const h = heroRef(rep.data);
    const shared = sharedClade(g.species);
    units.push({
      isGenus: true,
      id: g.slug,
      href: `/${gallery}/${g.slug}/`,
      name: g.genus,
      fam: shared.at(-1) ?? rep.data.family ?? rep.data.clade.at(-1) ?? '',
      cladePath: shared.length ? shared : expandClades(rep.data.clade),
      length: '',
      speciesCount: g.species.length,
      lengthM: Math.max(...g.species.map((s) => s.data.lengthM ?? 0)),
      massKg: Math.max(...g.species.map((s) => s.data.massKg ?? 0)),
      underRevision: false, // a genus card is never withheld; its species carry that flag individually
      img: await loadSkeletal(h.src),
      alt: h.alt,
      imgSrc: h.src,
    });
  } else {
    for (const t of g.species) {
      const h = heroRef(t.data);
      units.push({
        isGenus: false,
        id: t.id,
        href: `/${gallery}/${t.id}/`,
        name: t.data.taxon,
        fam: t.data.family ?? t.data.clade.at(-1) ?? '',
        cladePath: expandClades(t.data.clade),
        length: formatLength(t.data),
        speciesCount: 1,
        lengthM: t.data.lengthM ?? 0,
        massKg: t.data.massKg ?? 0,
        underRevision: t.data.underRevision,
        img: await loadSkeletal(h.src),
        alt: h.alt,
        imgSrc: h.src,
      });
    }
  }
}
units.sort((a, b) => a.name.localeCompare(b.name));

// ── Clade drill-down nav data (CLAUDE.md §5 faceting; lib/clades LANDMARKS = the curated chip
// pool). Counts are per-CARD (units), not per-taxon, so the drill-down totals always match what the
// grid shows — a collapsed genus counts once, at the shared clade it filters under. ──
const count: Record<string, number> = {};
const parent: Record<string, string> = {};
for (const u of units) {
  u.cladePath.forEach((c, i) => {
    count[c] = (count[c] ?? 0) + 1; // subtree count (cards nested at/under c)
    if (i > 0) parent[c] = u.cladePath[i - 1];
  });
}
const present = Object.keys(count);
const navData = {
  parent,
  count,
  landmarks: present.filter((c) => LANDMARKS.has(c)),
  root: present.find((c) => !(c in parent)) ?? meta.label, // the gallery's universal ancestor
  popularMin: POPULAR_MIN,
};

const title = `${meta.label} — skeletal reconstructions | Skeletal Drawing`;
const description = `${all.length} skeletal reconstructions of ${meta.label} by Scott Hartman — ${meta.intro}`;
---

<BaseLayout title={title} description={description}>
  <main class="wrap">
    <header class="page-head">
      <div>
        <p class="eyebrow">Gallery</p>
        <h1 class="display"><a href={`/${gallery}/`} id="gallery-home" title={`Back to all ${meta.label}`}>{meta.label}</a></h1>
        <p class="intro">{meta.intro}</p>
      </div>
      <div class="head-aside">
        <p class="count"><span id="count">{units.length}</span> reconstructions</p>
        <a class="to-search" href="/skeletals/">Search the database →</a>
      </div>
    </header>

    <!-- Clade drill-down nav (populated by the script from #navdata) -->
    <nav class="clade-nav" aria-label="Browse by clade">
      <div class="here-row">
        <span class="grp-label" id="here-label">You are here</span>
        <ol class="crumbs" id="crumbs"></ol>
      </div>
      <div class="descend">
        <span class="grp-label" id="descend-label">Go deeper</span>
        <div class="chip-row" id="descend-row"></div>
      </div>
      <div class="jump" id="jump-wrap">
        <span class="grp-label">Jump to</span>
        <div class="chip-row" id="jump-row"></div>
      </div>
    </nav>

    <div class="toolbar">
      <p class="showing"><span id="here-count"></span> in <span id="here-name" class="here-name"></span></p>
      <div class="tools">
        <label class="sort">Sort
          <select id="sort">
            <option value="name">Name · A–Z</option>
            <option value="length">Length · longest</option>
            <option value="mass">Mass · heaviest</option>
          </select>
        </label>
      </div>
    </div>

    <ul class="grid" id="grid">
      {units.map((u) => (
        <li
          class="card"
          data-name={u.name}
          data-length={u.lengthM}
          data-mass={u.massKg}
          data-clade={u.cladePath.join('|')}
        >
          <a href={u.href}>
            <div class="thumb">
              {u.underRevision ? (
                <span class="revising">Under revision</span>
              ) : (
                <>
                  {u.isGenus ? (
                    <span class="badge badge-count">{u.speciesCount} species</span>
                  ) : (
                    u.length && <span class="badge">{u.length}</span>
                  )}
                  {u.img ? (
                    <Image src={u.img} alt={u.alt} widths={[320, 640]} sizes="(max-width: 700px) 46vw, 300px" class="thumb-img" loading="lazy" />
                  ) : (
                    <img src={u.imgSrc} alt={u.alt} class="thumb-img" />
                  )}
                </>
              )}
            </div>
            <div class="body">
              <span class="text">
                <span class="name">{u.name}</span>
                <span class="fam">{u.fam}</span>
              </span>
              <span class="arrow">→</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </main>

  <script type="application/json" id="navdata" set:html={JSON.stringify(navData)} />
</BaseLayout>

<script>
  type Nav = {
    parent: Record<string, string>;
    count: Record<string, number>;
    landmarks: string[];
    root: string;
    popularMin: number;
  };
  const nav: Nav = JSON.parse(document.getElementById('navdata')!.textContent!);
  const LM = new Set(nav.landmarks);
  const { parent, count, root, popularMin } = nav;

  // ── clade helpers (mirror lib/clades, over the injected parent map) ──
  const ancestry = (c: string): string[] => {
    const a: string[] = [];
    let x: string | undefined = c;
    while (x) { a.unshift(x); x = parent[x]; }
    return a;
  };
  const isDesc = (c: string, X: string): boolean => c !== X && ancestry(c).includes(X);
  const closestLandmarkAncestor = (c: string): string | null => {
    let x = parent[c];
    while (x) { if (LM.has(x)) return x; x = parent[x]; }
    return null;
  };

  // nearest landmarks below X (nothing landmark-ish between) — the "go deeper" chips
  const descendChips = (X: string) =>
    [...LM].filter((L) => isDesc(L, X) && closestLandmarkAncestor(L) === X)
           .sort((a, b) => count[b] - count[a]);

  // popular landmarks anywhere below X — the "jump to" chips; mode decides how chains collapse
  const jumpChips = (X: string, exclude: Set<string>, mode: string) => {
    let cands = [...LM].filter(
      (L) => isDesc(L, X) && count[L] >= popularMin && !exclude.has(L),
    );
    if (mode === 'tips') // keep only the tip of each chain (drop candidates that are an ancestor of another)
      cands = cands.filter((L) => !cands.some((o) => o !== L && isDesc(o, L)));
    else if (mode === 'broad') // keep only the broadest of each chain (drop candidates nested in another)
      cands = cands.filter((L) => !cands.some((o) => o !== L && isDesc(L, o)));
    return cands.sort((a, b) => count[b] - count[a]);
  };

  // ── DOM ──
  const grid = document.getElementById('grid')!;
  const cards = [...grid.querySelectorAll<HTMLElement>('.card')];
  const countEl = document.getElementById('count')!;
  const crumbs = document.getElementById('crumbs')!;
  const hereLabel = document.getElementById('here-label')!;
  const descendRow = document.getElementById('descend-row')!;
  const descendLabel = document.getElementById('descend-label')!;
  const jumpRow = document.getElementById('jump-row')!;
  const jumpWrap = document.getElementById('jump-wrap')!;
  const hereName = document.getElementById('here-name')!;
  const hereCount = document.getElementById('here-count')!;
  const sortEl = document.getElementById('sort') as HTMLSelectElement;

  const CAP = 6;              // max chips shown at once (descend first, jumps fill the rest)
  const JUMP_MODE = 'tips';   // jump chips favour the branch tips over the backbone spine

  let node = root;

  const chipBtn = (clade: string, kind: 'descend' | 'jump') => {
    const b = document.createElement('button');
    b.className = `chip chip-${kind}`;
    b.dataset.clade = clade;
    b.innerHTML = `<span class="cname">${clade}</span><span class="cn">(${count[clade]})</span>`;
    b.addEventListener('click', () => setNode(clade));
    return b;
  };

  function renderNav() {
    // breadcrumb: landmark ancestry of the current node, each a step back up
    crumbs.innerHTML = '';
    const trail = ancestry(node).filter((c) => LM.has(c) || c === root);
    hereLabel.textContent = 'You are here'; // always shown — the reserved label column would sit blank otherwise
    trail.forEach((c, i) => {
      const li = document.createElement('li');
      if (i === trail.length - 1) {
        const s = document.createElement('span'); // current node: not clickable, styled as a filled pill
        s.className = 'crumb here';
        s.textContent = c;
        li.appendChild(s);
      } else {
        const b = document.createElement('button');
        b.className = 'crumb';
        b.textContent = c;
        b.addEventListener('click', () => setNode(c));
        li.appendChild(b);
      }
      crumbs.appendChild(li);
    });

    const descend = descendChips(node);
    const exclude = new Set<string>([node, ...descend]);
    const jumps = jumpChips(node, exclude, JUMP_MODE).slice(0, Math.max(0, CAP - descend.length));

    descendRow.innerHTML = '';
    descend.forEach((c) => descendRow.appendChild(chipBtn(c, 'descend')));
    descendLabel.parentElement!.style.display = descend.length ? '' : 'none';

    jumpRow.innerHTML = '';
    jumps.forEach((c) => jumpRow.appendChild(chipBtn(c, 'jump')));
    jumpWrap.style.display = jumps.length ? '' : 'none';

    hereName.textContent = node;
    hereCount.textContent = String(count[node] ?? 0);
  }

  function apply() {
    let shown = 0;
    for (const card of cards) {
      const clades = (card.dataset.clade ?? '').split('|');
      const ok = node === root || clades.includes(node);
      card.style.display = ok ? '' : 'none';
      if (ok) shown++;
    }
    countEl.textContent = String(shown);

    const key = sortEl.value;
    const visible = cards.filter((c) => c.style.display !== 'none');
    visible.sort((a, b) => {
      if (key === 'name') return (a.dataset.name ?? '').localeCompare(b.dataset.name ?? '');
      const f = (c: HTMLElement) => Number(c.dataset[key] ?? 0);
      return f(b) - f(a); // length / mass: descending
    });
    for (const c of visible) grid.appendChild(c);
  }

  function setNode(c: string) {
    node = c;
    renderNav();
    apply();
    document.querySelector('.clade-nav')?.scrollIntoView({ block: 'nearest' });
  }

  sortEl.addEventListener('change', apply);

  // The gallery title resets to the root of the tree (a familiar "home" escape hatch, esp. on
  // mobile). It's a real link to /<gallery>/ for no-JS + new-tab; JS makes it a smooth in-place reset.
  document.getElementById('gallery-home')?.addEventListener('click', (e) => {
    e.preventDefault();
    setNode(root);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Deep-link support: /<gallery>/#<Clade> opens the gallery already drilled to that clade (used by
  // the clade links in each skeletal page's eyebrow). Falls back to root for unknown/absent clades.
  const fromHash = decodeURIComponent(location.hash.replace(/^#/, ''));
  if (fromHash && count[fromHash]) node = fromHash;

  renderNav();
  apply();
  if (node !== root) document.querySelector('.clade-nav')?.scrollIntoView({ block: 'start' });
</script>

<style>
  .wrap { max-width: 1240px; margin: 0 auto; padding: 0 var(--pad-side); }

  .page-head {
    display: flex; flex-wrap: wrap; gap: 18px 32px; align-items: flex-end;
    justify-content: space-between; margin-top: 44px;
  }
  .eyebrow {
    margin: 0 0 10px; font-family: var(--font-mono); font-size: 12px;
    letter-spacing: .22em; text-transform: uppercase; color: var(--slate);
  }
  .display {
    margin: 0; font-style: italic; font-weight: 500;
    font-size: clamp(36px, 6vw, 60px); line-height: 1.0; letter-spacing: -.015em;
  }
  /* title doubles as a reset-to-top target; inherits the heading look, faint gold on hover as the only tell */
  .display a { color: inherit; text-decoration: none; transition: color .15s ease; }
  .display a:hover { color: var(--accent); }
  .intro { margin: 14px 0 0; font-size: 18px; line-height: 1.55; color: var(--ink); max-width: 60ch; }
  .count { margin: 0; font-family: var(--font-mono); font-size: 12px; letter-spacing: .12em; text-transform: uppercase; color: var(--slate); white-space: nowrap; }
  /* reverse of the search page's "Browse galleries →" — a quiet swap to search while browsing */
  .head-aside { display: flex; flex-direction: column; align-items: flex-end; gap: 9px; }
  .to-search {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
    color: var(--accent); text-decoration: none; white-space: nowrap;
  }
  .to-search:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* ── clade drill-down nav ── */
  /* Layout containers are in the template, so scoped styles reach them. The chips/crumbs INSIDE
     them are built in the client script (createElement) → they get no scope attribute → their
     styles must be global; see the is:global block after this one. */
  .clade-nav { margin: 30px 0 4px; padding-top: 20px; border-top: 1px solid var(--hair); }
  /* wrap so a long trail — or the full-width mobile label — drops the crumbs to the next line
     instead of forcing a horizontal scroll (CLAUDE.md: no horizontal scroll on mobile, anywhere) */
  .here-row { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; margin: 10px 0 26px; }
  .descend, .jump { display: flex; align-items: baseline; gap: 12px; margin: 10px 0; }
  .grp-label {
    flex-shrink: 0; width: 96px; white-space: nowrap; font-family: var(--font-mono); font-size: 10px;
    letter-spacing: .14em; text-transform: uppercase; color: var(--slate); padding-top: 3px;
  }
  .here-row .grp-label { padding-top: 0; }
  .crumbs { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; align-items: center; gap: 4px 2px; }
  .chip-row { display: flex; flex-wrap: wrap; gap: 8px; }

  .toolbar {
    display: flex; flex-wrap: wrap; gap: 12px 20px; align-items: center; justify-content: space-between;
    margin: 18px 0 24px; padding: 14px 0; border-top: 1px solid var(--hair); border-bottom: 1px solid var(--hair);
  }
  .showing { margin: 0; font-family: var(--font-mono); font-size: 12px; letter-spacing: .08em; color: var(--slate); }
  .here-name { color: var(--ink); }
  .tools { display: flex; flex-wrap: wrap; gap: 10px 16px; align-items: center; }
  .sort {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
    color: var(--slate); display: inline-flex; align-items: center; gap: 8px;
  }
  .sort select {
    font-family: var(--font-mono); font-size: 12px; padding: 6px 9px;
    border: 1px solid var(--hair-strong); border-radius: 4px; background: var(--plate); color: var(--ink);
  }

  .grid {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(296px, 1fr)); gap: 22px;
  }
  .card { border: 1px solid var(--hair-strong); background: var(--plate); border-radius: 4px; overflow: hidden; transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease; }
  .card:hover { border-color: var(--slate); transform: translateY(-3px); box-shadow: 0 10px 26px rgba(26, 24, 21, .10); }
  .card a { text-decoration: none; color: var(--ink); display: block; }
  .thumb { position: relative; aspect-ratio: 16 / 10; background: var(--plate); display: flex; align-items: center; justify-content: center; padding: 14px; }
  .thumb-img { width: 100%; height: 100%; object-fit: contain; }
  .badge {
    position: absolute; top: 10px; right: 10px; font-family: var(--font-mono); font-size: 10px;
    letter-spacing: .08em; text-transform: uppercase; color: var(--measure); background: #ffffffcc; padding: 2px 6px; border-radius: 3px;
  }
  /* genus-hub tell: the length badge is replaced by a species count, tinted gold so a hub card
     reads at a glance as "several skeletals inside" rather than a single reconstruction */
  .badge-count { color: var(--accent); border: 1px solid var(--accent-soft); }
  .revising {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
    color: var(--accent); border: 1px solid var(--accent-soft); border-radius: 4px;
    padding: 8px 12px; background: var(--accent-weak, #f3ece1);
  }
  .body { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; padding: 14px 16px; border-top: 1px solid var(--hair); }
  .text { display: flex; flex-direction: column; gap: 5px; min-width: 0; }
  .name { font-style: italic; font-size: 18px; line-height: 1.15; }
  .fam { font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--slate); }
  .arrow { color: var(--accent); flex-shrink: 0; }

  @media (max-width: 600px) {
    .wrap { padding: 0 18px; }
    .grp-label { width: 100%; padding-top: 0; }
    .descend, .jump { flex-direction: column; gap: 6px; }
    .grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 14px; }
    .name { font-size: 16px; }
  }
</style>

<!-- Chips and crumbs are created in the client script, so they never get Astro's scope attribute.
     These rules are global, but anchored under .clade-nav (which only exists on this page) so they
     can't leak onto .chip elsewhere in the site. -->
<style is:global>
  .clade-nav .crumbs li { display: inline-flex; align-items: center; }
  .clade-nav .crumbs li:not(:first-child)::before { content: '›'; color: var(--slate); margin: 0 9px; opacity: .7; }
  .clade-nav .crumb {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: .04em;
    background: none; border: 0; padding: 2px 2px; color: var(--slate);
    cursor: pointer; border-bottom: 1px solid transparent;
  }
  .clade-nav button.crumb:hover { color: var(--ink); border-bottom-color: var(--slate); }
  /* current node: heavier + larger ink type (no fill) — the always-on "You are here" label plus
     the plain text ancestors give it enough contrast without a box */
  .clade-nav .crumb.here {
    color: var(--ink); font-size: 15px; font-weight: 700; letter-spacing: .01em; cursor: default;
  }
  .clade-nav button:focus:not(:focus-visible) { outline: none; }

  .clade-nav .chip {
    display: inline-flex; align-items: baseline; font-family: var(--font-mono);
    font-size: 11px; letter-spacing: .08em; padding: 7px 11px; border-radius: 4px;
    border: 1px solid var(--hair-strong); background: var(--plate); color: var(--ink);
    cursor: pointer; transition: all .15s ease;
  }
  .clade-nav .chip .cn { margin-left: 6px; font-size: 10px; color: var(--slate); }
  .clade-nav .chip:hover { border-color: var(--slate); transform: translateY(-1px); }
