---
import { getCollection } from 'astro:content';
import SkeletalPage from '../../components/SkeletalPage.astro';
import GenusHub from '../../components/GenusHub.astro';
import SpecimenHub from '../../components/SpecimenHub.astro';

// One page per taxon, which resolves to one of three templates:
//   • SpecimenHub — a taxon with specimen children (e.g. /theropods/tyrannosaurus-rex/)
//   • SkeletalPage — a plain single taxon
//   • GenusHub     — a synthetic genus path aggregating ≥2 species (e.g. /…/diplodocus/)
export async function getStaticPaths() {
  const taxa = await getCollection('taxa');
  const specimens = await getCollection('specimens');
  const taxonIds = new Set(taxa.map((t) => t.id));

  const kidsByTaxon = new Map<string, typeof specimens>();
  for (const sp of specimens) {
    const arr = kidsByTaxon.get(sp.data.taxon) ?? [];
    arr.push(sp);
    kidsByTaxon.set(sp.data.taxon, arr);
  }

  const paths = taxa.map((entry) => {
    const kids = kidsByTaxon.get(entry.id) ?? [];
    return {
      params: { gallery: entry.data.gallery, taxon: entry.id },
      props: kids.length
        ? { entry, specimens: kids, hub: null }
        : { entry, specimens: null, hub: null },
    };
  });

  // Synthetic genus hubs: a gallery+genus with ≥2 taxa and no taxon already on that slug.
  const groups = new Map();
  for (const t of taxa) {
    const genus = t.data.taxon.split(' ')[0];
    const slug = genus.toLowerCase();
    const key = `${t.data.gallery}::${slug}`;
    if (!groups.has(key)) groups.set(key, { gallery: t.data.gallery, genus, slug, species: [] });
    groups.get(key).species.push(t);
  }
  for (const g of groups.values()) {
    if (g.species.length >= 2 && !taxonIds.has(g.slug)) {
      paths.push({
        params: { gallery: g.gallery, taxon: g.slug },
        props: { entry: null, specimens: null, hub: g },
      });
    }
  }
  return paths;
}

const { entry, specimens, hub } = Astro.props;
---

{
  hub ? (
    <GenusHub hub={hub} />
  ) : specimens ? (
    <SpecimenHub taxon={entry} specimens={specimens} />
  ) : (
    <SkeletalPage entry={entry} />
  )
}
