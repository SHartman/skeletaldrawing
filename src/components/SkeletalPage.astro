---
import { getCollection, render } from 'astro:content';
import { Picture, Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ScaleComparison from './ScaleComparison.astro';
import { loadSkeletal } from '../lib/images';
import {
  taxonImageGraph,
  formatLength,
  formatImperial,
  formatMass,
  isKnownMaterialOnly,
  heroRef,
  formatAuthor,
  taxonNameHtml,
} from '../lib/schema';
import { expandClades, cladeLadder } from '../lib/clades';

// Rendered by [gallery]/[taxon].astro for a single taxon. (Genus hubs go to GenusHub.astro.)
const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const kmOnly = isKnownMaterialOnly(d);
const underRevision = !!d.underRevision; // outdated skeletal withheld behind a placeholder + notice
const hero = heroRef(d); // reconstruction if present, else the known-material image
const heroImg = await loadSkeletal(hero.src);

// A separate "known material" section only when a taxon has BOTH images.
const showRigorousSection = !!(d.reconstruction && d.rigorous);
const rigImg = showRigorousSection ? await loadSkeletal(d.rigorous!.src) : null;

// Bonus figures (e.g. Malawisaurus armor), optimized.
const figs = await Promise.all(
  d.additionalFigures.map(async (f) => ({ ...f, img: await loadSkeletal(f.src) })),
);

// Absolute URLs: canonical page + stable image URLs for metadata.
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const imageUrl = new URL(hero.src, Astro.site).href;
const rigorousUrl = showRigorousSection ? new URL(d.rigorous!.src, Astro.site).href : undefined;

// Derived text (shares helpers with the JSON-LD so the two can't drift).
const cladePath = expandClades(d.clade); // full lineage, derived from the authored terminal clade
const ladder = cladeLadder(d.clade);     // landmark ancestors + terminal → the indented record ladder
const family = d.family ?? cladePath.at(-1);
// Metric is primary (scientific standard); append a US-friendly imperial conversion in parentheses.
// Skip the imperial when a custom lengthLabel override is set (it may be a range/non-numeric).
const ltMetric = formatLength(d);
const ltImperial = d.lengthLabel ? '' : formatImperial(d.lengthM);
const lt = ltImperial ? `${ltMetric} (${ltImperial})` : ltMetric;
const mass = formatMass(d.massKg);
// A nicknamed specimen gets a subtitle under the title, mirroring the specimen page (Sue) — so a
// nicknamed skeletal like Triceratops sp. “Yoshi” reads the same way and the name is prominent. The
// catalog number stays in the eyebrow + record; only the nickname is elevated here.
const specSub = d.specimenName ? `“${d.specimenName}”${d.specimenId ? ` · ${d.specimenId}` : ''}` : null;
// Eyebrow clades double as links back into the gallery: root → gallery top; family → gallery
// pre-filtered to that clade (via the /#Clade deep-link the gallery script reads). SpecimenId is text.
const rootClade = cladePath[0];
// `spec` marks the specimen-number part: the separator before it becomes a vertical bar instead of a
// slash, a subtle tell that the data type changed from taxonomy to a catalog number.
const eyebrowParts: { label: string; href: string | null; spec?: boolean }[] = [
  { label: rootClade, href: `/${d.gallery}/` },
  ...(family && family !== rootClade
    ? [{ label: family, href: `/${d.gallery}/#${encodeURIComponent(family)}` }]
    : []),
  ...(d.specimenId ? [{ label: d.specimenId, href: null, spec: true }] : []),
];
// Ensure the credit always carries the © (the CMS can strip it on save). Shown once,
// in the "Drawing" record cell below — the caption stays scale-only so the visible
// credit isn't tripled against the baked-in image mark + JSON-LD (CLAUDE.md §3).
const drawingCredit = d.drawingCredit.startsWith('©') ? d.drawingCredit : `© ${d.drawingCredit}`;
const caption = underRevision
  ? 'Placeholder — skeletal under revision, not the current reconstruction'
  : `${kmOnly ? 'Known material · ' : ''}Scale bar = ${d.scaleBar}`;

// Title-block cells (the Taxon cell is rendered separately for its mixed italic).
const restFields = [
  { k: 'Specimen', v: d.specimenId ?? '' }, // nickname (if any) is shown in the subtitle under the title
  { k: 'Also known as', v: d.alsoKnownAs.join(' · ') },
  { k: kmOnly ? 'Estimated length' : 'Reconstructed length', v: lt },
  { k: 'Wingspan', v: d.wingspanM != null ? `~${d.wingspanM} m` : '' },
  { k: 'Body mass', v: mass },
  { k: 'Life stage', v: d.lifeStage ?? '' },
  { k: 'Sex', v: d.sex ?? '' },
  { k: 'View', v: d.view },
  { k: 'Basis', v: d.basis ?? (kmOnly ? 'Known material only — too incompletely known to restore' : '') },
  { k: 'Drawing', v: drawingCredit },
].filter((f) => f.v);

// Related: same-gallery taxa, ranked by how much of the clade path they share.
const others = (await getCollection('taxa')).filter(
  (t) => t.id !== entry.id && t.data.gallery === d.gallery && !t.data.underRevision,
);
const shared = (t: (typeof others)[number]) =>
  expandClades(t.data.clade).filter((c) => cladePath.includes(c)).length;
others.sort((a, b) => shared(b) - shared(a) || a.data.taxon.localeCompare(b.data.taxon));
const related = await Promise.all(
  others.slice(0, 4).map(async (t) => ({
    id: t.id,
    data: t.data,
    img: await loadSkeletal(heroRef(t.data).src),
    alt: heroRef(t.data).alt,
    family: t.data.family ?? t.data.clade.at(-1),
  })),
);

// SEO payload.
const kind = underRevision
  ? 'skeletal reconstruction (under revision)'
  : kmOnly
    ? 'known skeletal material'
    : 'skeletal reconstruction';
const title = `${d.taxon} — ${kind}${d.specimenId ? ` · ${d.specimenId}` : ''} | Skeletal Drawing`;
const description = underRevision
  ? `Skeletal reconstruction of ${d.taxon} — currently under revision. An updated skeletal is in progress; the previous version is withheld to avoid circulating an outdated figure. © Scott Hartman, skeletaldrawing.com.`
  : kmOnly
    ? `Known skeletal material of ${d.taxon}${d.specimenId ? `, specimen ${d.specimenId}` : ''}${lt ? `, estimated length ${lt}` : ''} — preserved elements drawn in white. © Scott Hartman, skeletaldrawing.com.`
    : `Skeletal reconstruction of ${d.taxon}${d.specimenName ? ` (“${d.specimenName}”)` : ''}${d.specimenId ? `, specimen ${d.specimenId}` : ''}, ${d.view.toLowerCase()} view${lt ? `, ${lt}` : ''}. © Scott Hartman, skeletaldrawing.com.`;
// Under revision → a text-only CreativeWork (no ImageObject), so the page stays indexed for its
// metadata but we never assert the placeholder as the skeletal. Otherwise the full image graph.
const jsonLd = underRevision
  ? {
      '@context': 'https://schema.org',
      '@type': 'CreativeWork',
      '@id': pageUrl,
      name: `${d.taxon} — skeletal reconstruction (under revision)`,
      creativeWorkStatus: 'Under revision',
      creditText: d.creditText,
      creator: { '@type': 'Person', name: 'Scott Hartman', url: 'https://www.skeletaldrawing.com/about/' },
      about: { '@type': 'Thing', name: d.taxon, alternateName: `${d.taxon} ${formatAuthor(d.author, d.recombination)}` },
    }
  : taxonImageGraph(entry, { pageUrl, imageUrl, rigorousUrl });
---

<BaseLayout title={title} description={description} ogImage={underRevision ? undefined : imageUrl} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <main class="wrap">
    <!-- ===================== unified specimen card ===================== -->
    <article class="card">
      <span class="reg tl"></span><span class="reg tr"></span>
      <span class="reg bl"></span><span class="reg br"></span>

      <header class="card-header">
        <p class="eyebrow">
          {eyebrowParts.map((p, i) => (
            <Fragment>
              {i > 0 && <span class={p.spec ? 'sep sep-type' : 'sep'} aria-hidden="true">{p.spec ? '|' : '/'}</span>}
              {p.href ? <a href={p.href}>{p.label}</a> : <span>{p.label}</span>}
            </Fragment>
          ))}
        </p>
        <h1 class="binomial" set:html={taxonNameHtml(d.taxon)}></h1>
        {d.commonName && <p class="commonname">{d.commonName}</p>}
        {specSub && <p class="specsub">{specSub}</p>}
      </header>

      <figure class={underRevision ? 'plate is-revision' : 'plate'}>
        {underRevision && (
          <p class="revision-banner">
            <strong>Under revision.</strong> The skeletal of <em>{d.taxon}</em> is being updated; this
            placeholder stands in so the page stays available, and the outdated version is withheld to
            avoid circulating it. If you have an older copy, please treat it as superseded.
          </p>
        )}
        {heroImg ? (
          <Picture
            src={heroImg}
            formats={['avif', 'webp']}
            alt={hero.alt}
            widths={[640, 1120, 1680, 2240]}
            sizes="(min-width: 1180px) 1120px, 92vw"
            class="plate-img"
            loading="eager"
            fetchpriority="high"
          />
        ) : (
          <img src={hero.src} alt={hero.alt} class="plate-img" fetchpriority="high" />
        )}
        <figcaption class="caption">{caption}</figcaption>
      </figure>

      <div class="titleblock">
        <div class="cell">
          <div class="k">Taxon</div>
          <div class="v"><span class="tx" set:html={taxonNameHtml(d.taxon)}></span> {formatAuthor(d.author, d.recombination)}</div>
        </div>
        {restFields.map((f) => (
          <div class="cell">
            <div class="k">{f.k}</div>
            <div class="v">{f.v}</div>
          </div>
        ))}
        <div class="cell cell-clade">
          <div class="k">Clade</div>
          <ol class="ladder">
            {ladder.map((c, i) => <li style={`--i:${i}`}>{c}</li>)}
          </ol>
        </div>
      </div>
    </article>

    <p class="licensing">
      Available for editorial, museum &amp; print licensing —
      <a href={d.license}>inquiries &amp; rates →</a>
    </p>

    <!-- ===================== methodology prose ===================== -->
    <div class="prose">
      <Content />
    </div>

    <!-- ============ known-material (rigorous), only when paired with a reconstruction ============ -->
    {showRigorousSection && (
      <section class="rigorous">
        <p class="eyebrow">The evidence</p>
        <h2 class="rig-h">What the specimen actually preserves</h2>
        <figure class="rig-fig">
          <div class="rig-plate">
            {rigImg ? (
              <Picture
                src={rigImg}
                formats={['avif', 'webp']}
                alt={d.rigorous!.alt}
                widths={[640, 1120, 1680, 2240]}
                sizes="(min-width: 1180px) 1120px, 92vw"
                class="plate-img"
                loading="lazy"
              />
            ) : (
              <img src={d.rigorous!.src} alt={d.rigorous!.alt} class="plate-img" />
            )}
          </div>
          <figcaption class="rig-cap">
            Known material{d.specimenId ? ` of ${d.specimenId}` : ''}: elements preserved in the
            specimen are shown in white; unpreserved regions are left as black silhouette.
          </figcaption>
        </figure>
      </section>
    )}

    <!-- ============ bonus figures (e.g. speculative armor), only when present ============ -->
    {figs.length > 0 && (
      <section class="extras">
        {figs.map((f) => (
          <figure class="rig-fig">
            <div class="rig-plate">
              {f.img ? (
                <Picture
                  src={f.img}
                  formats={['avif', 'webp']}
                  alt={f.alt}
                  widths={[640, 1120, 1680, 2240]}
                  sizes="(min-width: 1180px) 1120px, 92vw"
                  class="plate-img"
                  loading="lazy"
                />
              ) : (
                <img src={f.src} alt={f.alt} class="plate-img" />
              )}
            </div>
            {(f.caption || f.credit) && (
              <figcaption class="rig-cap">
                {f.caption}
                {f.credit && (
                  <span class="fig-credit">
                    {f.source ? (
                      <a href={f.source} target="_blank" rel="noopener">{f.credit}</a>
                    ) : (
                      f.credit
                    )}
                  </span>
                )}
              </figcaption>
            )}
          </figure>
        ))}
      </section>
    )}

    <!-- ============ ontogenetic growth-series overlay (e.g. Maiasaura), only when flagged ============ -->
    {d.growthSeries && (
      <ScaleComparison
        taxonId={`${entry.id}-growth`}
        total={0}
        heading="Growth series"
        note={d.growthNote ?? 'The growth stages above, drawn to a common scale.'}
      />
    )}

    <!-- ===================== related ===================== -->
    {related.length > 0 && (
      <section class="related">
        <h2 class="related-h">Related reconstructions</h2>
        <div class="related-grid">
          {related.map((t) => (
            <a class="related-card" href={`/${d.gallery}/${t.id}/`}>
              <div class="related-thumb">
                {t.img ? (
                  <Image src={t.img} alt={t.alt} widths={[260, 520]} sizes="220px" class="related-img" loading="lazy" />
                ) : (
                  <img src={heroRef(t.data).src} alt={t.alt} class="related-img" />
                )}
              </div>
              <div class="related-name" set:html={taxonNameHtml(t.data.taxon)}></div>
              <div class="related-fam">{t.family}</div>
            </a>
          ))}
        </div>
      </section>
    )}

  </main>
</BaseLayout>

<style>
  .wrap { max-width: var(--measure-max); margin: 0 auto; padding: 0 var(--pad-side); }

  /* ---- specimen card ---- */
  .card {
    margin-top: 40px;
    border: 1px solid var(--hair-strong);
    background: var(--plate);
    position: relative;
    animation: riseIn .6s cubic-bezier(.2, .7, .2, 1) both;
  }
  .reg {
    position: absolute; width: 14px; height: 14px;
    border-color: var(--slate); border-style: solid; border-width: 0;
  }
  .reg.tl { top: -1px; left: -1px; border-top-width: 2px; border-left-width: 2px; }
  .reg.tr { top: -1px; right: -1px; border-top-width: 2px; border-right-width: 2px; }
  .reg.bl { bottom: -1px; left: -1px; border-bottom-width: 2px; border-left-width: 2px; }
  .reg.br { bottom: -1px; right: -1px; border-bottom-width: 2px; border-right-width: 2px; }

  .card-header { padding: 26px 34px 22px; border-bottom: 1px solid var(--hair); }
  .eyebrow {
    margin: 0 0 10px; font-family: var(--font-mono); font-size: 12px;
    letter-spacing: .24em; text-transform: uppercase; color: var(--slate);
  }
  /* the clade parts of the eyebrow link back to the gallery (a back-to-gallery affordance people
     tap on mobile); they inherit the eyebrow look, with a faint underline on hover as the only tell */
  .eyebrow a { color: inherit; text-decoration: none; border-bottom: 1px solid transparent; transition: color .15s ease, border-color .15s ease; }
  .eyebrow a:hover { color: var(--ink); border-bottom-color: var(--accent-soft); }
  .eyebrow .sep { margin: 0 .5em; opacity: .5; }
  /* vertical bar at the taxonomy→specimen boundary — a subtle "data type changed" tell */
  .eyebrow .sep-type { margin: 0 .62em; opacity: .38; }
  /* italic comes from the inner <i> (taxonNameHtml), so an open-nomenclature "sp." stays roman */
  .binomial {
    margin: 0; font-weight: 500;
    font-size: clamp(40px, 6.5vw, 68px); line-height: 1.0; letter-spacing: -.015em;
  }
  /* popular/vernacular name under the binomial (esp. extant taxa) — a real name, so roman serif */
  .commonname { margin: 10px 0 0; font-size: 19px; color: var(--slate); }
  /* nicknamed-specimen subtitle under the title — mirrors the specimen page (e.g. Sue) */
  .specsub { margin: 12px 0 0; font-family: var(--font-mono); font-size: 14px; letter-spacing: .06em; color: var(--ink); }

  .plate { margin: 0; padding: 32px 34px 26px; }
  .plate-img { width: 100%; height: auto; display: block; }
  .caption {
    margin-top: 16px; font-family: var(--font-mono); font-size: 11px;
    letter-spacing: .1em; text-transform: uppercase; color: var(--measure);
  }

  .titleblock {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    border-top: 1px solid var(--hair);
  }
  .cell {
    padding: 15px 22px;
    border-right: 1px solid var(--hair); border-bottom: 1px solid var(--hair);
  }
  .cell .k {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em;
    text-transform: uppercase; color: var(--slate); margin-bottom: 7px;
  }
  .cell .v { font-size: 15.5px; }
  .cell .v em { font-style: italic; }
  /* Clade as an indented, rank-free ladder (modern phylogenetic-nomenclature style) rather than an
     arrow run-on — pruned to landmark clades + the taxon's own, each line stepped further in. Spans
     the full record width so deep chains have room. */
  .cell-clade { grid-column: 1 / -1; }
  .ladder { margin: 0; padding: 0; list-style: none; }
  .ladder li { font-size: 14px; line-height: 1.32; padding-left: calc(var(--i) * 0.8em); }
  .ladder li:last-child { font-weight: 600; }

  .licensing { margin: 16px 0 0; font-size: 14.5px; color: var(--slate); }
  .licensing a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-soft); }

  /* ---- methodology prose (Content is global markup) ---- */
  .prose { max-width: 64ch; padding: 36px 0 6px; }
  .prose :global(p) { font-size: 19px; line-height: 1.66; margin: 0 0 1.1em; }
  /* Matches the article/blog prose treatment. Covers the auto-linked taxon names (which arrive as
     <a><em>Genus</em></a>) as well as any link written into a description by hand. */
  .prose :global(a) { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-soft); }
  .prose :global(a:hover) { border-bottom-color: var(--accent); }
  .prose :global(p:first-of-type::first-letter) {
    font-size: 3.1em; line-height: .82; float: left; padding: 6px 10px 0 0;
    font-weight: 500; color: var(--accent-bright);
  }

  /* ---- rigorous / known material ---- */
  .rigorous { margin: 40px 0 0; border-top: 1px solid var(--hair); padding-top: 30px; }
  .rig-h {
    margin: 0 0 20px; font-style: italic; font-weight: 500;
    font-size: clamp(26px, 4vw, 38px); line-height: 1.05;
  }
  .rig-fig { margin: 0; }
  .rig-plate { background: var(--plate); border: 1px solid var(--hair); padding: 30px 34px; }
  .rig-cap {
    margin-top: 16px; font-size: 15px; color: var(--slate);
    line-height: 1.55; max-width: 760px;
  }

  /* ---- bonus figures ---- */
  .extras {
    border-top: 1px solid var(--hair); margin-top: 40px; padding-top: 30px;
    display: grid; gap: 30px;
  }

  /* ---- related ---- */
  .related { border-top: 1px solid var(--hair); margin-top: 46px; padding-top: 28px; }
  .related-h {
    margin: 0 0 20px; font-family: var(--font-mono); font-size: 12px; font-weight: 400;
    letter-spacing: .22em; text-transform: uppercase; color: var(--slate);
  }
  /* auto-fit (not auto-fill) so the cards expand to fill the row and line up with the
     record row above — no phantom empty track / ragged gap on wide screens. */
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
  .related-card { text-decoration: none; color: var(--ink); }
  .related-thumb {
    aspect-ratio: 4 / 3; background: var(--plate); border: 1px solid var(--hair); margin-bottom: 10px;
    display: flex; align-items: center; justify-content: center; padding: 10px;
  }
  .related-img { width: 100%; height: 100%; object-fit: contain; }
  .related-name { font-size: 17px; } /* italic from the inner <i> (taxonNameHtml) */
  .related-fam {
    font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .12em;
    text-transform: uppercase; color: var(--slate); margin-top: 3px;
  }

  /* ---- under revision: an outdated skeletal withheld behind an honest placeholder ---- */
  .revision-banner {
    margin: 0 0 16px; padding: 12px 16px; border-radius: 5px;
    background: var(--accent-weak, #f3ece1); border: 1px solid var(--accent-soft);
    font-size: 14.5px; line-height: 1.55; color: var(--ink);
  }
  .revision-banner strong { color: var(--accent); }
  .is-revision .caption { color: var(--accent); }

  /* attribution for a third-party (CC-BY paper) figure */
  .fig-credit { display: block; margin-top: 4px; font-size: 12.5px; color: var(--measure); }
  .fig-credit a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-soft); }

  /* ---- mobile: keep everything within the viewport ---- */
  @media (max-width: 600px) {
    .wrap { padding: 0 18px; }
    .card-header, .plate { padding-left: 18px; padding-right: 18px; }
    .rig-plate { padding: 18px; }
    .cell { padding: 14px 16px; }
    /* Two-up related cards (matches the gallery grid) — reads as a clearly separate
       footer of suggestions and cuts the scrolling to see them all. */
    .related-grid { grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 14px; }
    .related-name { font-size: 16px; }
  }
</style>
