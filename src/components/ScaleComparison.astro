---
import silData from '../data/silhouettes.json';
import human from '../data/human.json';

// Tail-tip-aligned scale comparison (CLAUDE.md §5). Silhouettes are traced offline
// (scripts/silhouette.mjs) to vector paths in src/data/silhouettes.json; here they're
// scaled to a common meter, grounded on a shared baseline, and aligned at the tail —
// so size reads as how far each snout reaches. Largest = soft-filled envelope; the
// rest are outlines (the smallest dashed). Renders nothing if no silhouettes exist.
const {
  taxonId,
  total,
  heading,
  href,
  linkLabel = 'See the hub →',
  note,
  toolHref,
  toolLabel = 'Create your own comparison →',
} = Astro.props as {
  taxonId: string;
  total: number;
  heading?: string; // home-context: a serif title + optional hub link instead of the mono label
  href?: string;
  linkLabel?: string;
  note?: string;
  toolHref?: string; // optional CTA to the interactive comparison tool, shown above the hub link
  toolLabel?: string;
};
const raw = (silData as Record<string, any[]>)[taxonId] ?? [];
const items = [...raw].sort((a, b) => b.lengthM - a.lengthM);

const padL = 16;
const padT = 16;
const hasData = items.length > 0;

// Normalize the drawing so the largest silhouette is always ~TARGET_W units wide, whatever the animals'
// real size. Otherwise a 0.4 m Archaeopteryx yields a tiny viewBox that the browser scales up ~12x to fill
// the figure — blowing up the user-unit ruler text and the figure box. A constant content width keeps text
// and strokes rendering at a consistent size from songbird to supersaurus. (PXM = svg units per metre.)
const TARGET_W = 900;
const rawMaxWidthM = hasData ? Math.max(...items.map((it) => it.widthM ?? it.lengthM)) : 1;
const PXM = TARGET_W / rawMaxWidthM;

// Scale by the silhouette's true HORIZONTAL extent in meters so pose doesn't distort size: an
// upright taxon (raised neck, therizinosaur, bird) has widthM < lengthM and no longer inflates.
// widthM falls back to lengthM when unmeasured, so horizontal taxa are unaffected. lengthM stays
// the biological label (legend + ruler); only the geometry uses widthM. (See silhouette pipeline.)
const scaled = items.map((it, idx) => {
  const s = (PXM * (it.widthM ?? it.lengthM)) / it.w;
  return { ...it, idx, s, sw: it.w * s, sh: it.h * s };
});

const maxLen = hasData ? Math.max(...scaled.map((d) => d.lengthM)) : 0; // biological max — for the aria label
// Horizontal layout follows the actual rendered silhouette widths (sw), not lengthM, so a raised-neck
// largest taxon (widthM < lengthM) doesn't leave dead space or over-run the ruler.
const maxSW = hasData ? Math.max(...scaled.map((d) => d.sw)) : 0;
const maxSH = hasData ? Math.max(...scaled.map((d) => d.sh)) : 0;

// Human scale reference — the owner's traced adult (~1.8 m). Shown only while it doesn't dwarf the
// subjects: for sub-metre animals (e.g. the Archaeopteryx specimens) a 1.8 m human towers ~10x and
// overflows the frame, so we drop it and let the ruler carry the scale.
const humanH = 1.8 * PXM;
const humanScale = humanH / human.h;
const humanW = +(human.w * humanScale).toFixed(1);
const humanGap = 40;
const showHuman = hasData && humanH <= 3 * maxSH;

const guideX = padL + maxSW;
const groundY = padT + (showHuman ? Math.max(maxSH, humanH) : maxSH);
const humanX = guideX + humanGap;

// Ground ruler, 0 at the tail. Metres for big animals; switch to centimetres once the whole group is
// under ~2 m, or a metre ruler shows no ticks at all for a 40 cm Archaeopteryx. Spacing + labels adapt.
const spanM = maxSW / PXM; // horizontal span of the largest silhouette, in metres
const cmRuler = spanM < 2;
const tickM = cmRuler ? 0.1 : 1; // tick every 10 cm or every 1 m
const tickPx = tickM * PXM;
const nTicks = Math.floor(spanM / tickM);
const labelEvery = cmRuler ? (spanM < 0.6 ? 1 : 5) : 5; // label every Nth tick
const tickValue = (i: number) => (cmRuler ? i * 10 : i); // cm or m at tick i
const rulerUnit = cmRuler ? 'centimeters from tail tip' : 'meters from tail tip';

const rulerY = groundY + 20;
const rightPad = (showHuman ? humanGap + humanW : 0) + 26;
const vbW = Math.round(guideX + rightPad);
const vbH = Math.round(rulerY + 18);

const tx = (d: any) => `translate(${(guideX - d.sw).toFixed(1)} ${(groundY - d.sh).toFixed(1)}) scale(${d.s.toFixed(4)})`;
---

{
  hasData && (
    <section class="scale">
      {heading ? (
        <div class="sc-head">
          <h2 class="sc-title">{heading}</h2>
          {(toolHref || href) && (
            <div class="sc-links">
              {toolHref && <a class="sc-link sc-tool" href={toolHref}>{toolLabel}</a>}
              {href && <a class="sc-link sc-hub" href={href}>{linkLabel}</a>}
            </div>
          )}
        </div>
      ) : (
        <h2 class="sec-h">Scale comparison <span class="sec-sub">— tails aligned, drawn to a common scale</span></h2>
      )}
      <figure class="fig">
        <svg viewBox={`0 0 ${vbW} ${vbH}`} role="img" aria-label={`Scale comparison of ${items.length} skeletals, ${maxLen} meters at the largest${showHuman ? ', with a 1.8-meter adult and a child for scale' : ''}`}>
          {/* ground line */}
          <line x1={padL} y1={groundY} x2={showHuman ? humanX + humanW : guideX} y2={groundY} class="ground" />

          {/* ground ruler: ticks each unit (m or 10 cm), labels every few, 0 at the tail */}
          {Array.from({ length: nTicks + 1 }, (_, m) => {
            const x = guideX - m * tickPx;
            const major = m % labelEvery === 0;
            return (
              <g>
                <line x1={x} y1={groundY} x2={x} y2={groundY + (major ? 8 : 4)} class={major ? 'tick major' : 'tick'} />
                {major && <text x={x} y={rulerY + 6} class="tick-label">{tickValue(m)}</text>}
              </g>
            );
          })}
          <text x={guideX - nTicks * tickPx} y={rulerY + 6} class="tick-unit" text-anchor="start" dx="-2" dy="14">{rulerUnit}</text>

          {/* silhouettes: largest filled, others outlined (smallest dashed) */}
          {scaled
            .slice()
            .reverse()
            .map((d) => (
              <path
                d={d.path}
                transform={tx(d)}
                class={d.idx === 0 ? 'sil envelope' : d.idx === scaled.length - 1 ? 'sil outline dashed' : 'sil outline'}
              />
            ))}

          {/* tail-tip guide */}
          <line x1={guideX} y1={padT} x2={guideX} y2={groundY} class="guide" />

          {/* human scale reference — adult + child, adult at 1.8 m (dropped when it would dwarf the subjects) */}
          {showHuman && (
            <>
              <g transform={`translate(${humanX} ${groundY - humanH}) scale(${humanScale.toFixed(4)})`}>
                <path d={human.path} class="human" />
              </g>
              <text x={humanX + humanW / 2} y={groundY + 14} class="human-label" text-anchor="middle">1.8 m</text>
            </>
          )}
        </svg>

        <figcaption class="legend">
          {scaled.map((d) => (
            <span class="leg-item">
              <span class={d.idx === 0 ? 'sw sw-fill' : d.idx === scaled.length - 1 ? 'sw sw-dash' : 'sw sw-line'} />
              <span class="leg-name">{d.label}</span>
              <span class="leg-len">{d.lengthM} m</span>
            </span>
          ))}
        </figcaption>
        <p class="note">{note ?? `Overlay shows ${items.length} of ${total} documented skeletals — the full set is in the table below.`}</p>
      </figure>
    </section>
  )
}

<style>
  .scale { margin-top: 40px; }
  .sec-h {
    margin: 0 0 18px; font-family: var(--font-mono); font-size: 12px; font-weight: 400;
    letter-spacing: .2em; text-transform: uppercase; color: var(--slate);
  }
  .sec-sub { letter-spacing: 0; text-transform: none; }

  .sc-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px 20px; flex-wrap: wrap; margin: 0 0 18px; }
  .sc-title { font-weight: 500; font-size: clamp(24px, 3vw, 30px); letter-spacing: -.01em; margin: 0; }
  .sc-links { display: flex; flex-direction: column; align-items: flex-end; gap: 7px; text-align: right; padding-top: 4px; }
  .sc-link {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
    color: var(--accent); text-decoration: none; white-space: nowrap;
  }
  .sc-tool { font-weight: 600; border-bottom: 1px solid var(--accent-soft); padding-bottom: 2px; } /* the CTA */
  .sc-tool + .sc-hub { color: var(--slate); } /* hub goes secondary ONLY when the tool CTA is above it */
  .sc-tool + .sc-hub:hover { color: var(--accent); }

  .fig {
    margin: 0; border: 1px solid var(--hair-strong); background: var(--plate);
    border-radius: 4px; padding: 24px 26px 18px;
  }
  svg { display: block; width: 100%; height: auto; max-width: 960px; margin: 0 auto; overflow: visible; }

  .ground { stroke: var(--ink); stroke-width: 1.5; vector-effect: non-scaling-stroke; }
  .guide { stroke: var(--accent); stroke-width: 1; stroke-dasharray: 4 4; vector-effect: non-scaling-stroke; opacity: .6; }
  .tick { stroke: var(--slate); stroke-width: 1; vector-effect: non-scaling-stroke; }
  .tick.major { stroke: var(--ink); }
  .tick-label { font-family: var(--font-mono); font-size: 11px; fill: var(--slate); text-anchor: middle; }
  .tick-unit { font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em; fill: var(--measure); text-transform: uppercase; }

  .sil { vector-effect: non-scaling-stroke; }
  .envelope { fill: var(--accent); fill-opacity: .16; stroke: var(--accent); stroke-width: 1.6; }
  .outline { fill: none; stroke: var(--ink); stroke-width: 1.4; stroke-opacity: .85; }
  .outline.dashed { stroke: var(--slate); stroke-dasharray: 6 4; }

  .human { fill: var(--slate); stroke: none; }
  .human-label { font-family: var(--font-mono); font-size: 11px; fill: var(--slate); }

  .legend {
    display: flex; flex-wrap: wrap; gap: 8px 22px; margin: 18px 0 0;
    padding-top: 16px; border-top: 1px solid var(--hair);
  }
  .leg-item { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; }
  .sw { width: 22px; height: 12px; flex: 0 0 auto; border-radius: 2px; }
  .sw-fill { background: var(--accent); opacity: .55; border: 1px solid var(--accent); }
  .sw-line { height: 0; border-top: 2px solid var(--ink); }
  .sw-dash { height: 0; border-top: 2px dashed var(--slate); }
  .leg-name { font-style: italic; }
  .leg-len { font-family: var(--font-mono); font-size: 12px; color: var(--slate); }

  .note { margin: 14px 0 0; font-size: 13.5px; color: var(--slate); }

  @media (max-width: 600px) {
    .fig { padding: 16px 14px 14px; }
    .legend { gap: 6px 16px; }
  }
</style>
