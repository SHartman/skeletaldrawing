---
import Glyph from './Glyph.astro';

// Data-driven primary nav. "Learn" is the single inviting door for first-party
// guides/articles AND curated external resources (the /learn/ hub) — it reads as an
// invitation where a bare "Resources" gets skipped. Remaining hrefs are placeholders
// until each section exists; reshuffling IA later is a one-line edit.
// Browse vs. search are split by affordance: the "Galleries" WORD opens the image-forward
// gallery grid (/galleries/) — what a menu label implies — while the trailing search ICON opens
// the typeahead launcher (/skeletals/), the universal "jump to a specific thing" affordance. No
// dropdown; the two doors cross-link, so neither is a dead end.
const nav = [
  { label: 'Galleries', href: '/galleries/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Learn', href: '/learn/' },
  { label: 'About', href: '/about/' },
  // Store hidden until a public storefront ships (~late summer/fall 2026). For now the store is
  // only used to send clients private Square payment links, so a header entry would dead-end.
  // { label: 'Store', href: '/store/' },
];
---

<header class="masthead">
  <div class="inner">
    <a class="logo" href="/">
      <span class="logo-text"><span class="logo-strong">Skeletal</span> <span class="logo-italic">Drawing</span></span>
      <Glyph />
    </a>
    <nav aria-label="Primary">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      <a class="search-link" href="/skeletals/" aria-label="Search skeletals" title="Search skeletals">
        <svg class="search-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.3-4.3"></path>
        </svg>
      </a>
    </nav>
  </div>
</header>

<style>
  .masthead {
    background: var(--mast-bg);
    border-bottom: 1px solid var(--mast-border);
  }
  .inner {
    max-width: var(--measure-max);
    margin: 0 auto;
    padding: 22px var(--pad-side);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
  }
  .logo {
    text-decoration: none;
    color: var(--mast-fg);
    font-size: 23px;
    letter-spacing: .01em;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 11px;
  }
  .logo-strong { font-weight: 600; }
  .logo-italic { font-style: italic; color: var(--mast-link); }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 26px;
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .16em;
  }
  nav a { color: var(--mast-link); text-decoration: none; }
  nav a:hover { color: var(--mast-fg); }

  /* search affordance: an icon, not a word — sits at the end of the nav, aligned to the mono caps */
  nav a.search-link { display: inline-flex; align-items: center; }
  .search-ic { width: 15px; height: 15px; display: block; }

  /* Mobile: stack the logo and nav so nothing forces horizontal scroll. */
  @media (max-width: 600px) {
    .inner { flex-direction: column; align-items: flex-start; gap: 14px; }
    nav { gap: 14px 18px; }
  }
</style>
