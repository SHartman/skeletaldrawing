---
import { getCollection, render } from 'astro:content';
import { Picture, Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadSkeletal } from '../lib/images';
import {
  specimenImageGraph,
  specimenHero,
  specimenIsKnownMaterialOnly,
  formatMeters,
  formatImperial,
  formatMass,
  formatAuthor,
} from '../lib/schema';
import { expandClades } from '../lib/clades';

// One specimen, rendered as an instance of the skeletal-page template at a nested
// URL. `taxon` is the parent taxa entry (supplies binomial, author, clade, hub link).
const { entry, taxon } = Astro.props;
const s = entry.data;
const t = taxon.data;
const { Content } = await render(entry);

const kmOnly = specimenIsKnownMaterialOnly(s);
const hero = specimenHero(s);
const heroImg = await loadSkeletal(hero.src);

const showRigorous = !!(s.reconstruction && s.rigorous);
const rigImg = showRigorous ? await loadSkeletal(s.rigorous!.src) : null;

const figs = await Promise.all(
  (s.additionalFigures ?? []).map(async (f) => ({ ...f, img: await loadSkeletal(f.src) })),
);

const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const imageUrl = new URL(hero.src, Astro.site).href;
const rigorousUrl = showRigorous ? new URL(s.rigorous!.src, Astro.site).href : undefined;
const figures = figs.map((f) => ({ url: new URL(f.src, Astro.site).href, label: f.label, alt: f.alt }));

// Credit shown once, in the "Drawing" record cell below — caption stays scale-only so
// the visible credit isn't tripled against the baked-in mark + JSON-LD (CLAUDE.md §3).
const drawingCredit = s.drawingCredit.startsWith('©') ? s.drawingCredit : `© ${s.drawingCredit}`;
const caption = `${kmOnly ? 'Known material · ' : ''}Scale bar = ${s.scaleBar}`;

// Metric primary, US-friendly imperial in parentheses (length only — not femur).
const ltImperial = formatImperial(s.lengthM);
const lt = ltImperial ? `${formatMeters(s.lengthM)} (${ltImperial})` : formatMeters(s.lengthM);
const femur = formatMeters(s.femurM);
const mass = formatMass(s.massKg);
const tClades = expandClades(t.clade);
const family = t.family ?? tClades.at(-1);
// Single eyebrow "root / family / catalog" — mirrors the skeletal landing page, with no separate
// breadcrumb line. Root + family link into the gallery; the catalog (this specimen) stays plain text.
// The parent hub is still reached from the Taxon record cell and the "all specimens" back-link below.
const rootClade = tClades[0];
// `spec` marks the catalog-number part: the separator before it becomes a vertical bar instead of a
// slash, a subtle tell that the data type changed from taxonomy to a specimen number.
const eyebrowParts: { label: string; href: string | null; spec?: boolean }[] = [
  { label: rootClade, href: `/${t.gallery}/` },
  ...(family && family !== rootClade
    ? [{ label: family, href: `/${t.gallery}/#${encodeURIComponent(family)}` }]
    : []),
  ...(s.catalog ? [{ label: s.catalog, href: null, spec: true }] : []),
];
const idSub = s.nickname ? `“${s.nickname}” · ${s.catalog}` : s.catalog;

const restFields: { k: string; v: string; href?: string }[] = [
  { k: 'Specimen', v: s.catalog },
  { k: 'Repository', v: s.repository ?? '', href: s.repositoryUrl },
  { k: 'Formation', v: s.formation ?? '' },
  { k: 'Locality', v: s.locality ?? '' },
  { k: kmOnly ? 'Estimated length' : 'Reconstructed length', v: lt },
  { k: 'Femur length', v: femur },
  { k: 'Body mass', v: mass },
  { k: 'Completeness', v: s.completenessPct != null ? `~${s.completenessPct}%` : '' },
  { k: 'Sex', v: s.sex ?? '' },
  { k: 'Collected', v: s.collectedYear != null ? String(s.collectedYear) : '' },
  { k: 'View', v: s.view },
  { k: 'Basis', v: s.basis ?? '' },
  { k: 'Drawing', v: drawingCredit },
].filter((f) => f.v);

// Related: the sibling specimens of the same taxon.
const siblings = (await getCollection('specimens')).filter(
  (x) => x.data.taxon === s.taxon && x.id !== entry.id,
);
siblings.sort((a, b) => (b.data.lengthM ?? 0) - (a.data.lengthM ?? 0));
const related = await Promise.all(
  siblings.slice(0, 4).map(async (x) => ({
    id: x.id,
    data: x.data,
    img: await loadSkeletal(specimenHero(x.data).src),
    alt: specimenHero(x.data).alt,
  })),
);

const hubUrl = `/${t.gallery}/${taxon.id}/`;

const kind = kmOnly ? 'known skeletal material' : 'skeletal reconstruction';
const title = `${t.taxon} — ${s.catalog}${s.nickname ? ` (“${s.nickname}”)` : ''} ${kind} | Skeletal Drawing`;
const description = kmOnly
  ? `Known skeletal material of ${t.taxon} specimen ${s.catalog}${s.nickname ? ` (“${s.nickname}”)` : ''}${lt ? `, estimated length ${lt}` : ''} — preserved elements drawn in white. © Scott Hartman, skeletaldrawing.com.`
  : `Skeletal reconstruction of ${t.taxon} specimen ${s.catalog}${s.nickname ? ` (“${s.nickname}”)` : ''}, ${s.view.toLowerCase()} view${lt ? `, ${lt}` : ''}. © Scott Hartman, skeletaldrawing.com.`;
const jsonLd = specimenImageGraph(entry, { taxonName: t.taxon, author: t.author, recombination: t.recombination, pageUrl, imageUrl, rigorousUrl, figures });
---

<BaseLayout title={title} description={description} ogImage={imageUrl} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <main class="wrap">
    <article class="card">
      <span class="reg tl"></span><span class="reg tr"></span>
      <span class="reg bl"></span><span class="reg br"></span>

      <header class="card-header">
        <p class="eyebrow">
          {eyebrowParts.map((p, i) => (
            <Fragment>
              {i > 0 && <span class={p.spec ? 'sep sep-type' : 'sep'} aria-hidden="true">{p.spec ? '|' : '/'}</span>}
              {p.href ? <a href={p.href}>{p.label}</a> : <span>{p.label}</span>}
            </Fragment>
          ))}
        </p>
        <h1 class="binomial">{t.taxon}</h1>
        {t.commonName && <p class="commonname">{t.commonName}</p>}
        <p class="specsub">{idSub}</p>
      </header>

      <figure class="plate">
        {heroImg ? (
          <Picture
            src={heroImg}
            formats={['avif', 'webp']}
            alt={hero.alt}
            widths={[640, 1120, 1680, 2240]}
            sizes="(min-width: 1180px) 1120px, 92vw"
            class="plate-img"
            loading="eager"
            fetchpriority="high"
          />
        ) : (
          <img src={hero.src} alt={hero.alt} class="plate-img" fetchpriority="high" />
        )}
        <figcaption class="caption">{caption}</figcaption>
      </figure>

      <div class="titleblock">
        <div class="cell">
          <div class="k">Taxon</div>
          <div class="v"><a href={hubUrl}><em>{t.taxon}</em></a> {formatAuthor(t.author, t.recombination)}</div>
        </div>
        {restFields.map((f) => (
          <div class="cell">
            <div class="k">{f.k}</div>
            <div class="v">
              {f.href ? <a href={f.href} target="_blank" rel="noopener">{f.v}</a> : f.v}
            </div>
          </div>
        ))}
      </div>
    </article>

    <p class="licensing">
      Available for editorial, museum &amp; print licensing —
      <a href={s.license}>inquiries &amp; rates →</a>
    </p>

    <div class="prose">
      <Content />
    </div>

    {showRigorous && (
      <section class="rigorous">
        <p class="eyebrow">The evidence</p>
        <h2 class="rig-h">What {s.catalog} actually preserves</h2>
        <figure class="rig-fig">
          <div class="rig-plate">
            {rigImg ? (
              <Picture
                src={rigImg}
                formats={['avif', 'webp']}
                alt={s.rigorous!.alt}
                widths={[640, 1120, 1680, 2240]}
                sizes="(min-width: 1180px) 1120px, 92vw"
                class="plate-img"
                loading="lazy"
              />
            ) : (
              <img src={s.rigorous!.src} alt={s.rigorous!.alt} class="plate-img" />
            )}
          </div>
          <figcaption class="rig-cap">
            Known material of {s.catalog}: elements preserved in the specimen are shown in white;
            unpreserved regions are left as black silhouette. This is the evidence the reconstruction
            above is built on.
          </figcaption>
        </figure>
      </section>
    )}

    {figs.length > 0 && (
      <section class="extras">
        {figs.map((f) => (
          <figure class="rig-fig">
            {f.label && <p class="eyebrow fig-label">{f.label}</p>}
            <div class="rig-plate">
              {f.img ? (
                <Picture
                  src={f.img}
                  formats={['avif', 'webp']}
                  alt={f.alt}
                  widths={[640, 1120, 1680, 2240]}
                  sizes="(min-width: 1180px) 1120px, 92vw"
                  class="plate-img"
                  loading="lazy"
                />
              ) : (
                <img src={f.src} alt={f.alt} class="plate-img" />
              )}
            </div>
            {f.caption && <figcaption class="rig-cap">{f.caption}</figcaption>}
          </figure>
        ))}
      </section>
    )}

    {related.length > 0 && (
      <section class="related">
        <h2 class="related-h">Other {t.taxon} specimens</h2>
        <div class="related-grid">
          {related.map((x) => (
            <a class="related-card" href={`/${t.gallery}/${taxon.id}/${x.id}/`}>
              <div class="related-thumb">
                {x.img ? (
                  <Image src={x.img} alt={x.alt} widths={[260, 520]} sizes="220px" class="related-img" loading="lazy" />
                ) : (
                  <img src={specimenHero(x.data).src} alt={x.alt} class="related-img" />
                )}
              </div>
              <div class="related-name">{x.data.catalog}</div>
              <div class="related-fam">{x.data.nickname ? `“${x.data.nickname}”` : t.family}</div>
            </a>
          ))}
        </div>
        <p class="back"><a href={hubUrl}>← all <em>{t.taxon}</em> specimens</a></p>
      </section>
    )}

  </main>
</BaseLayout>

<style>
  .wrap { max-width: var(--measure-max); margin: 0 auto; padding: 0 var(--pad-side); }

  .card {
    margin-top: 34px;
    border: 1px solid var(--hair-strong);
    background: var(--plate);
    position: relative;
    animation: riseIn .6s cubic-bezier(.2, .7, .2, 1) both;
  }
  .reg {
    position: absolute; width: 14px; height: 14px;
    border-color: var(--slate); border-style: solid; border-width: 0;
  }
  .reg.tl { top: -1px; left: -1px; border-top-width: 2px; border-left-width: 2px; }
  .reg.tr { top: -1px; right: -1px; border-top-width: 2px; border-right-width: 2px; }
  .reg.bl { bottom: -1px; left: -1px; border-bottom-width: 2px; border-left-width: 2px; }
  .reg.br { bottom: -1px; right: -1px; border-bottom-width: 2px; border-right-width: 2px; }

  .card-header { padding: 26px 34px 22px; border-bottom: 1px solid var(--hair); }
  .eyebrow {
    margin: 0 0 10px; font-family: var(--font-mono); font-size: 12px;
    letter-spacing: .24em; text-transform: uppercase; color: var(--slate);
  }
  .eyebrow a { color: inherit; text-decoration: none; border-bottom: 1px solid transparent; transition: color .15s ease, border-color .15s ease; }
  .eyebrow a:hover { color: var(--ink); border-bottom-color: var(--accent-soft); }
  .eyebrow .sep { margin: 0 .5em; opacity: .5; }
  /* vertical bar at the taxonomy→specimen boundary — a subtle "data type changed" tell */
  .eyebrow .sep-type { margin: 0 .62em; opacity: .38; }
  .binomial {
    margin: 0; font-style: italic; font-weight: 500;
    font-size: clamp(40px, 6.5vw, 68px); line-height: 1.0; letter-spacing: -.015em;
  }
  .commonname { margin: 10px 0 0; font-size: 19px; color: var(--slate); } /* parent taxon's popular name */
  .specsub {
    margin: 12px 0 0; font-family: var(--font-mono); font-size: 14px;
    letter-spacing: .06em; color: var(--ink);
  }

  .plate { margin: 0; padding: 32px 34px 26px; }
  .plate-img { width: 100%; height: auto; display: block; }
  .caption {
    margin-top: 16px; font-family: var(--font-mono); font-size: 11px;
    letter-spacing: .1em; text-transform: uppercase; color: var(--measure);
  }

  .titleblock {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    border-top: 1px solid var(--hair);
  }
  .cell {
    padding: 15px 22px;
    border-right: 1px solid var(--hair); border-bottom: 1px solid var(--hair);
  }
  .cell .k {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em;
    text-transform: uppercase; color: var(--slate); margin-bottom: 7px;
  }
  .cell .v { font-size: 15.5px; }
  .cell .v em { font-style: italic; }
  .cell .v a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--accent-soft); }

  .licensing { margin: 16px 0 0; font-size: 14.5px; color: var(--slate); }
  .licensing a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent-soft); }

  .prose { max-width: 64ch; padding: 36px 0 6px; }
  .prose :global(p) { font-size: 19px; line-height: 1.66; margin: 0 0 1.1em; }
  .prose :global(p:first-of-type::first-letter) {
    font-size: 3.1em; line-height: .82; float: left; padding: 6px 10px 0 0;
    font-weight: 500; color: var(--accent-bright);
  }
  .prose :global(strong) { font-weight: 600; }

  .rigorous { margin: 40px 0 0; border-top: 1px solid var(--hair); padding-top: 30px; }
  .rig-h {
    margin: 0 0 20px; font-style: italic; font-weight: 500;
    font-size: clamp(26px, 4vw, 38px); line-height: 1.05;
  }
  .rig-fig { margin: 0; }
  .fig-label { margin: 0 0 14px; }
  .rig-plate { background: var(--plate); border: 1px solid var(--hair); padding: 30px 34px; }
  .rig-cap {
    margin-top: 16px; font-size: 15px; color: var(--slate);
    line-height: 1.55; max-width: 760px;
  }

  .extras {
    border-top: 1px solid var(--hair); margin-top: 40px; padding-top: 30px;
    display: grid; gap: 40px;
  }

  .related { border-top: 1px solid var(--hair); margin-top: 46px; padding-top: 28px; }
  .related-h {
    margin: 0 0 20px; font-family: var(--font-mono); font-size: 12px; font-weight: 400;
    letter-spacing: .22em; text-transform: uppercase; color: var(--slate);
  }
  .related-h { font-style: normal; }
  /* auto-FILL (not auto-fit): keeps empty columns so a lone sibling card stays ~thumbnail-sized and
     reads as a link, instead of stretching to full width and blurring (matches the hub cards). */
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; }
  .related-card { text-decoration: none; color: var(--ink); }
  .related-thumb {
    aspect-ratio: 4 / 3; background: var(--plate); border: 1px solid var(--hair); margin-bottom: 10px;
    display: flex; align-items: center; justify-content: center; padding: 10px;
  }
  .related-img { width: 100%; height: 100%; object-fit: contain; }
  .related-name { font-family: var(--font-mono); font-size: 14px; letter-spacing: .04em; }
  .related-fam {
    font-style: italic; font-size: 14px; color: var(--slate); margin-top: 3px;
  }
  .back { margin: 22px 0 0; font-size: 14.5px; }
  .back a { color: var(--accent); text-decoration: none; }
  .back em { font-style: italic; }

  @media (max-width: 600px) {
    .wrap { padding: 0 18px; }
    .card-header, .plate { padding-left: 18px; padding-right: 18px; }
    .rig-plate { padding: 18px; }
    .cell { padding: 14px 16px; }
    /* Two-up related cards (matches the gallery grid). */
    .related-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 14px; }
  }
</style>
