---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadSkeletal } from '../lib/images';
import { expandClades } from '../lib/clades';
import ScaleComparison from './ScaleComparison.astro';
import {
  heroRef,
  formatLength,
  formatMeters,
  formatAuthor,
  isKnownMaterialOnly,
  specimenHero,
  specimenIsKnownMaterialOnly,
} from '../lib/schema';

// Genus hub: aggregates a multi-species genus. A species that has documented specimens is
// FLATTENED — each specimen becomes its own card/row — so the hub surfaces every skeletal in
// the genus, not just one per species (e.g. Diplodocus: carnegii + the two hallorum specimens).
const { hub } = Astro.props;
const gallery: string = hub.gallery;

// Single eyebrow "root / family", both linked into the gallery — mirrors the skeletal landing page,
// with no separate breadcrumb line and no genus echo (the big title already states the genus). The
// "family" is the deepest clade every species in the genus shares (a genus is monophyletic).
const speciesPaths = hub.species.map((s: any) => expandClades(s.data.clade));
const rootClade = speciesPaths[0][0];
let familyClade = rootClade;
const minDepth = Math.min(...speciesPaths.map((p: string[]) => p.length));
for (let i = 0; i < minDepth; i++) {
  const c = speciesPaths[0][i];
  if (speciesPaths.every((p: string[]) => p[i] === c)) familyClade = c;
  else break;
}
const eyebrowParts: { label: string; href: string }[] = [
  { label: rootClade, href: `/${gallery}/` },
  ...(familyClade && familyClade !== rootClade
    ? [{ label: familyClade, href: `/${gallery}/#${encodeURIComponent(familyClade)}` }]
    : []),
];

const speciesIds = new Set(hub.species.map((s: any) => s.id));
const specimens = (await getCollection('specimens')).filter((sp) => speciesIds.has(sp.data.taxon));
const byTaxon = new Map<string, any[]>();
for (const sp of specimens) {
  const arr = byTaxon.get(sp.data.taxon) ?? [];
  arr.push(sp);
  byTaxon.set(sp.data.taxon, arr);
}

// One member per skeletal: a species' specimens if it has any, else the species itself.
interface Member {
  href: string;
  taxon: string;
  author: string;
  recombination: boolean;
  sub: string; // catalog (specimen) or family (plain species)
  lengthM: number | null;
  lengthLabel: string;
  img: Awaited<ReturnType<typeof loadSkeletal>>;
  alt: string;
  km: boolean;
  specimen: string;
}
const members: Member[] = [];
for (const t of hub.species) {
  const kids = byTaxon.get(t.id) ?? [];
  if (kids.length) {
    for (const k of kids) {
      const h = specimenHero(k.data);
      members.push({
        href: `/${gallery}/${t.id}/${k.id}/`,
        taxon: t.data.taxon,
        author: t.data.author,
        recombination: t.data.recombination,
        sub: k.data.catalog,
        lengthM: k.data.lengthM ?? null,
        lengthLabel: formatMeters(k.data.lengthM),
        img: await loadSkeletal(h.src),
        alt: h.alt,
        km: specimenIsKnownMaterialOnly(k.data),
        specimen: k.data.catalog,
      });
    }
  } else {
    const h = heroRef(t.data);
    members.push({
      href: `/${gallery}/${t.id}/`,
      taxon: t.data.taxon,
      author: t.data.author,
      recombination: t.data.recombination,
      sub: t.data.family ?? t.data.clade.at(-1) ?? '',
      lengthM: t.data.lengthM ?? null,
      lengthLabel: formatLength(t.data),
      img: await loadSkeletal(h.src),
      alt: h.alt,
      km: isKnownMaterialOnly(t.data),
      specimen: t.data.specimenId ?? '',
    });
  }
}
members.sort((a, b) => (b.lengthM ?? 0) - (a.lengthM ?? 0)); // largest first

const lengths = members.map((m) => m.lengthM).filter((n): n is number => n != null);
const sizeRange = lengths.length
  ? Math.min(...lengths) === Math.max(...lengths)
    ? `~${Math.max(...lengths)} m`
    : `${Math.min(...lengths)}–${Math.max(...lengths)} m`
  : '—';

const speciesCount = hub.species.length;
const title = `${hub.genus} — skeletal reconstructions | Skeletal Drawing`;
const description = `The genus ${hub.genus} by Scott Hartman — ${members.length} documented skeletals across ${speciesCount} species, ${sizeRange} in length, each with a full record.`;
---

<BaseLayout title={title} description={description} ogType="article">
  <main class="wrap">
    <header class="hub-head">
      <div class="head-main">
        <p class="eyebrow">
          {eyebrowParts.map((p, i) => (
            <Fragment>
              {i > 0 && <span class="sep" aria-hidden="true">/</span>}
              <a href={p.href}>{p.label}</a>
            </Fragment>
          ))}
        </p>
        <h1 class="display"><em>{hub.genus}</em></h1>
        <p class="intro">
          {members.length} documented skeletals across {speciesCount} {speciesCount === 1 ? 'species' : 'species'}
          of <em>{hub.genus}</em>, each drawn to a common method in left lateral view. Pick one below,
          or compare their records in the table.
        </p>
      </div>
      <dl class="facts">
        <div><dt>Skeletals shown</dt><dd>{members.length}</dd></div>
        <div><dt>Species</dt><dd>{speciesCount}</dd></div>
        <div><dt>Size range</dt><dd>{sizeRange}</dd></div>
      </dl>
    </header>

    <section class="block">
      <h2 class="sec-h">Skeletals</h2>
      <ul class="cards">
        {members.map((m) => (
          <li class="card">
            <a href={m.href}>
              <div class="thumb">
                {m.lengthLabel && <span class="badge">{m.lengthLabel}</span>}
                {m.km && <span class="badge badge-km">known material</span>}
                {m.img ? (
                  <Image src={m.img} alt={m.alt} widths={[320, 640]} sizes="(max-width: 700px) 46vw, 320px" class="thumb-img" loading="lazy" />
                ) : (
                  <img src={m.href} alt={m.alt} class="thumb-img" />
                )}
              </div>
              <div class="cbody">
                <span class="cnames">
                  <span class="cname">{m.taxon}</span>
                  <span class="csub">{m.sub}</span>
                </span>
                <span class="arrow">→</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <ScaleComparison taxonId={hub.slug} total={members.length} />

    <section class="block">
      <h2 class="sec-h">All documented skeletals <span class="sec-sub">— tap a column to sort</span></h2>
      <div class="table-wrap">
        <table id="sptable">
          <thead>
            <tr>
              <th data-key="name">Taxon</th>
              <th data-key="author">Author</th>
              <th data-key="length" class="num">Length</th>
              <th data-key="specimen">Specimen</th>
              <th aria-hidden="true"></th>
            </tr>
          </thead>
          <tbody>
            {members.map((m) => (
              <tr
                data-name={m.taxon}
                data-author={m.author}
                data-length={m.lengthM ?? 0}
                data-specimen={m.specimen}
              >
                <td><a href={m.href}><em>{m.taxon}</em></a></td>
                <td class="muted">{formatAuthor(m.author, m.recombination)}</td>
                <td class="num">{m.lengthLabel || '—'}</td>
                <td class="muted">{m.specimen || '—'}</td>
                <td class="num"><a href={m.href}>View →</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const table = document.getElementById('sptable');
  if (table) {
    const tbody = table.querySelector('tbody')!;
    const rows = [...tbody.querySelectorAll('tr')];
    const headers = [...table.querySelectorAll<HTMLElement>('th[data-key]')];
    let sortKey = 'name';
    let asc = true;
    const numeric = (k: string) => k === 'length';
    headers.forEach((th) =>
      th.addEventListener('click', () => {
        const key = th.dataset.key!;
        asc = sortKey === key ? !asc : true;
        sortKey = key;
        headers.forEach((h) => h.removeAttribute('aria-sort'));
        th.setAttribute('aria-sort', asc ? 'ascending' : 'descending');
        rows.sort((a, b) => {
          const r = numeric(key)
            ? Number(a.dataset[key] ?? 0) - Number(b.dataset[key] ?? 0)
            : (a.dataset[key] ?? '').localeCompare(b.dataset[key] ?? '');
          return asc ? r : -r;
        });
        rows.forEach((row) => tbody.appendChild(row));
      }),
    );
  }
</script>

<style>
  .wrap { max-width: var(--measure-max); margin: 0 auto; padding: 0 var(--pad-side); }

  .hub-head {
    display: flex; flex-wrap: wrap; gap: 20px 40px; align-items: flex-end;
    justify-content: space-between; margin: 34px 0 0; padding-bottom: 26px;
    border-bottom: 1px solid var(--hair);
  }
  .eyebrow {
    margin: 0 0 10px; font-family: var(--font-mono); font-size: 12px;
    letter-spacing: .22em; text-transform: uppercase; color: var(--slate);
  }
  .eyebrow a { color: inherit; text-decoration: none; border-bottom: 1px solid transparent; transition: color .15s ease, border-color .15s ease; }
  .eyebrow a:hover { color: var(--ink); border-bottom-color: var(--accent-soft); }
  .eyebrow .sep { margin: 0 .5em; opacity: .5; }
  .display {
    margin: 0; font-style: italic; font-weight: 500;
    font-size: clamp(46px, 8vw, 86px); line-height: 1.0; letter-spacing: -.015em;
  }
  .intro { margin: 16px 0 0; font-size: 18px; line-height: 1.6; color: var(--ink); max-width: 58ch; }
  .head-main { flex: 1 1 360px; }
  .facts { margin: 0; display: grid; gap: 14px; }
  .facts div { border-top: 2px solid var(--ink); padding-top: 8px; min-width: 130px; }
  .facts dt {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em;
    text-transform: uppercase; color: var(--slate); margin-bottom: 4px;
  }
  .facts dd { margin: 0; font-size: 19px; }

  .block { margin-top: 40px; }
  .sec-h {
    margin: 0 0 18px; font-family: var(--font-mono); font-size: 12px; font-weight: 400;
    letter-spacing: .2em; text-transform: uppercase; color: var(--slate);
  }
  .sec-sub { letter-spacing: 0; text-transform: none; }

  .cards {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(272px, 1fr)); gap: 22px;
  }
  .card {
    border: 1px solid var(--hair-strong); background: var(--plate); border-radius: 4px;
    overflow: hidden; transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
  }
  .card:hover { border-color: var(--slate); transform: translateY(-3px); box-shadow: 0 10px 26px rgba(26,24,21,.10); }
  .card a { text-decoration: none; color: var(--ink); display: block; }
  .thumb { position: relative; aspect-ratio: 16 / 10; display: flex; align-items: center; justify-content: center; padding: 14px; }
  .thumb-img { width: 100%; height: 100%; object-fit: contain; }
  .badge {
    position: absolute; top: 10px; right: 10px; font-family: var(--font-mono); font-size: 10px;
    letter-spacing: .08em; text-transform: uppercase; color: var(--measure); background: #ffffffcc;
    padding: 2px 6px; border-radius: 3px;
  }
  .badge-km { right: auto; left: 10px; color: var(--slate); }
  .cbody { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; padding: 13px 16px; border-top: 1px solid var(--hair); }
  .cnames { display: flex; flex-direction: column; gap: 2px; }
  .cname { font-style: italic; font-size: 18px; }
  .csub { font-family: var(--font-mono); font-size: 12px; letter-spacing: .04em; color: var(--slate); }
  .arrow { color: var(--accent); }

  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 15px; }
  th, td { text-align: left; padding: 11px 14px; border-bottom: 1px solid var(--hair); white-space: nowrap; }
  thead th {
    font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .12em; text-transform: uppercase;
    color: var(--slate); font-weight: 400; cursor: pointer; user-select: none; border-bottom: 2px solid var(--ink);
  }
  thead th[data-key]:hover { color: var(--ink); }
  thead th[aria-sort]::after { content: " ▲"; color: var(--accent); font-size: 9px; }
  thead th[aria-sort="descending"]::after { content: " ▼"; }
  td a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--accent-soft); }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  th.num { text-align: right; }
  td.muted { color: var(--slate); }

  @media (max-width: 600px) {
    .wrap { padding: 0 18px; }
    .cards { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 14px; }
    .cname { font-size: 16px; }
  }
</style>
