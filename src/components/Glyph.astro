---
// Brand glyph — a Psittacosaurus silhouette, traced from the owner's logo art. A throwback
// to the earliest skeletaldrawing.com logos, and chosen on purpose: its big head and short
// tail keep the shape legible at small sizes where a long-tailed theropod turns to mush.
// Fills with `currentColor` so it inherits the surrounding logo text color (white on the
// home hero, cream on the dark masthead). Decorative — the wordmark carries the name.
//
// Sizes ITSELF via width/height attributes + its own scoped style. Parent-scoped CSS can't
// reach this svg across the component boundary, so sizing must live here (or be passed in).
interface Props {
  height?: number; // rendered height in px; width derives from the silhouette aspect
  class?: string;
}
const { height = 28, class: cls } = Astro.props;
const width = Math.round((height * 1368) / 489);
const SIL =
  'M567 0L629 4L674 13L705 25L812 73L833 84L863 103L935 158L997 202L1020 214L1070 235L1125 252L1137 253L1208 267L1227 269L1297 270L1339 274L1367 283L1368 289L1366 291L1359 291L1343 287L1321 287L1195 303L1145 303L1101 300L1060 293L996 277L907 248L838 220L795 210L782 210L778 216L771 221L735 231L725 235L724 237L732 255L740 265L779 292L798 309L808 327L814 355L824 383L829 389L831 395L841 403L843 407L843 413L846 418L855 426L861 428L859 432L843 431L843 441L840 448L835 453L833 460L824 468L822 474L818 478L813 481L807 482L802 486L796 487L788 486L785 483L780 483L770 489L768 488L768 485L771 482L770 481L766 480L757 484L753 483L754 479L760 474L766 471L777 469L783 465L794 463L798 460L808 448L811 439L810 428L803 417L804 401L800 387L783 353L763 322L753 312L735 300L721 294L682 285L656 273L645 265L640 265L616 271L563 274L560 278L557 289L557 360L554 369L546 383L529 396L499 413L497 420L483 435L483 438L479 445L473 451L467 452L459 461L456 471L453 470L452 465L450 464L440 472L431 473L427 471L420 474L414 479L414 474L407 472L404 469L396 469L391 472L387 472L387 470L395 462L407 458L411 454L428 450L439 443L448 430L451 415L480 397L494 386L506 374L508 370L518 362L522 354L527 335L527 308L523 290L514 273L493 272L467 268L433 261L413 255L410 256L429 284L428 299L398 371L397 385L399 392L396 396L393 396L389 392L388 393L388 401L385 404L386 411L384 419L382 421L382 426L377 429L375 435L372 437L370 434L370 413L372 411L372 406L371 405L363 414L352 421L351 419L355 405L362 394L359 392L346 396L345 394L352 383L357 379L362 370L362 364L365 355L377 331L379 319L388 289L322 243L294 227L279 214L265 195L259 192L229 185L188 168L181 168L122 195L98 204L91 205L71 218L64 217L55 213L30 195L29 190L40 179L46 178L48 181L50 180L49 173L44 166L42 165L34 169L33 175L15 190L11 186L5 171L0 149L0 126L2 116L13 86L21 81L35 68L41 65L63 62L84 54L96 54L100 52L107 52L116 55L128 52L163 50L187 55L208 63L250 87L265 91L284 91L312 80L404 34L449 17L506 3L530 1L566 1Z';
---

